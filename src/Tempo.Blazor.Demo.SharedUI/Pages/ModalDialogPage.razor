@page "/modal-dialog"
@using Tempo.Blazor.Components.Feedback
@using Tempo.Blazor.Components.Buttons

<PageTitle>Modal & Dialog – Tempo.Blazor</PageTitle>

<!-- Page Header -->
<div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Modal & Dialog</h1>
    <p class="text-slate-600 dark:text-slate-400">Modern modal windows and dialogs with beautiful animations and UX.</p>
</div>

<!-- Basic Modal -->
<section class="demo-section">
    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Basic Modal</h2>
    <div class="flex flex-wrap gap-3">
        <TmButton OnClick="() => _showBasicModal = true" Variant="ButtonVariant.Primary">
            Open Modal
        </TmButton>
    </div>
</section>

<!-- Modal Sizes -->
<section class="demo-section">
    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Modal Sizes</h2>
    <div class="flex flex-wrap gap-3">
        <TmButton OnClick="() => { _showSizedModal = true; _modalSize = ModalSize.Small; }" Variant="ButtonVariant.Secondary">
            Small
        </TmButton>
        <TmButton OnClick="() => { _showSizedModal = true; _modalSize = ModalSize.Medium; }" Variant="ButtonVariant.Secondary">
            Medium
        </TmButton>
        <TmButton OnClick="() => { _showSizedModal = true; _modalSize = ModalSize.Large; }" Variant="ButtonVariant.Secondary">
            Large
        </TmButton>
        <TmButton OnClick="() => { _showSizedModal = true; _modalSize = ModalSize.XLarge; }" Variant="ButtonVariant.Secondary">
            XLarge
        </TmButton>
        <TmButton OnClick="() => { _showSizedModal = true; _modalSize = ModalSize.Fullscreen; }" Variant="ButtonVariant.Secondary">
            Fullscreen
        </TmButton>
    </div>
</section>

<!-- Dialog Types -->
<section class="demo-section">
    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Dialog Types</h2>
    <div class="flex flex-wrap gap-3">
        <TmButton OnClick="() => ShowAlert(DialogVariant.Info)" Variant="ButtonVariant.Ghost">
            <TmIcon Name="info" Class="mr-2" />
            Info Alert
        </TmButton>
        <TmButton OnClick="() => ShowAlert(DialogVariant.Success)" Variant="ButtonVariant.Ghost">
            <TmIcon Name="check-circle" Class="mr-2" />
            Success Alert
        </TmButton>
        <TmButton OnClick="() => ShowAlert(DialogVariant.Warning)" Variant="ButtonVariant.Ghost">
            <TmIcon Name="alert-triangle" Class="mr-2" />
            Warning Alert
        </TmButton>
        <TmButton OnClick="() => ShowAlert(DialogVariant.Error)" Variant="ButtonVariant.Ghost">
            <TmIcon Name="x-circle" Class="mr-2" />
            Error Alert
        </TmButton>
    </div>
</section>

<!-- Confirm Dialog -->
<section class="demo-section">
    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Confirm Dialog</h2>
    <div class="flex flex-wrap gap-3">
        <TmButton OnClick="ShowConfirm" Variant="ButtonVariant.Primary">
            Show Confirm
        </TmButton>
        <TmButton OnClick="ShowDangerConfirm" Variant="ButtonVariant.Danger">
            Dangerous Action
        </TmButton>
    </div>
    
    @if (_confirmResult.HasValue)
    {
        <div class="mt-4 p-4 rounded-lg @(_confirmResult.Value ? "bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800" : "bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700")">
            <p class="text-sm @(_confirmResult.Value ? "text-green-700 dark:text-green-300" : "text-gray-700 dark:text-gray-300")">
                User clicked: <strong>@(_confirmResult.Value ? "OK" : "Cancel")</strong>
            </p>
        </div>
    }
</section>

<!-- Prompt Dialog -->
<section class="demo-section">
    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Prompt Dialog</h2>
    <div class="flex flex-wrap gap-3">
        <TmButton OnClick="ShowPrompt" Variant="ButtonVariant.Primary">
            Enter Name
        </TmButton>
    </div>
    
    @if (!string.IsNullOrEmpty(_promptResult))
    {
        <div class="mt-4 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg">
            <p class="text-sm text-blue-700 dark:text-blue-300">
                You entered: <strong>@_promptResult</strong>
            </p>
        </div>
    }
</section>

<!-- Custom Modal Content -->
<section class="demo-section">
    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Custom Modal Content</h2>
    <div class="flex flex-wrap gap-3">
        <TmButton OnClick="() => _showCustomModal = true" Variant="ButtonVariant.Secondary">
            Open Custom Modal
        </TmButton>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════
   MODALS & DIALOGS
   ═══════════════════════════════════════════════════════════════ -->

<!-- Basic Modal -->
<TmModal Show="_showBasicModal"
         OnClose="() => _showBasicModal = false"
         Title="Modal Title"
         Subtitle="This is a subtitle that provides additional context">
    <p>This is the modal body content. You can put any content here including forms, text, images, etc.</p>
    <div class="mt-4 p-4 bg-slate-50 dark:bg-slate-800 rounded-lg">
        <p class="text-sm text-slate-600 dark:text-slate-400">
            Modals are great for focusing user attention on a specific task or information.
        </p>
    </div>
</TmModal>

<!-- Sized Modal -->
<TmModal Show="_showSizedModal"
         OnClose="() => _showSizedModal = false"
         Title="@($"{_modalSize} Modal")"
         Size="_modalSize">
    <p>This modal demonstrates the <strong>@_modalSize</strong> size variant.</p>
    <p class="mt-2 text-slate-600 dark:text-slate-400">
        Choose the appropriate size for your content to ensure optimal readability and UX.
    </p>
</TmModal>

<!-- Alert Dialog -->
<TmDialog Show="_showAlert"
          Type="DialogType.Alert"
          Variant="_alertVariant"
          Title="@_alertTitle"
          Message="@_alertMessage"
          OnResult="OnAlertResult" />

<!-- Confirm Dialog -->
<TmDialog Show="_showConfirm"
          Type="DialogType.Confirm"
          Variant="DialogVariant.Info"
          Title="@_confirmTitle"
          Message="@_confirmMessage"
          IsDangerous="_confirmIsDangerous"
          OkButtonText="@(_confirmIsDangerous ? "Delete" : "OK")"
          CancelButtonText="Cancel"
          OnResult="OnConfirmResult" />

<!-- Prompt Dialog -->
<TmDialog Show="_showPrompt"
          Type="DialogType.Prompt"
          Variant="DialogVariant.Info"
          Title="Enter Your Name"
          Message="Please enter your name to continue:"
          DefaultValue="John Doe"
          PromptPlaceholder="Type your name..."
          OkButtonText="Submit"
          CancelButtonText="Cancel"
          OnPromptResult="OnPromptResult" />

<!-- Custom Modal -->
<TmModal Show="_showCustomModal"
         OnClose="() => _showCustomModal = false"
         Title="Custom Content"
         Size="ModalSize.Medium"
         ShowFooter="false">
    
    <div class="space-y-4">
        <div class="flex items-center gap-4 p-4 bg-green-50 dark:bg-green-900/20 rounded-lg">
            <div class="w-12 h-12 rounded-full bg-green-100 dark:bg-green-800 flex items-center justify-center">
                <TmIcon Name="check" Color="IconColor.Success" Size="IconSize.Lg" />
            </div>
            <div>
                <h4 class="font-semibold text-green-900 dark:text-green-100">Success!</h4>
                <p class="text-sm text-green-700 dark:text-green-300">Your changes have been saved.</p>
            </div>
        </div>
        
        <p class="text-slate-600 dark:text-slate-400">
            You can create completely custom modal content with any components and styling.
        </p>
        
        <div class="flex gap-2">
            <span class="px-3 py-1 text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-full">Custom</span>
            <span class="px-3 py-1 text-xs font-medium bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 rounded-full">Flexible</span>
            <span class="px-3 py-1 text-xs font-medium bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300 rounded-full">Powerful</span>
        </div>
        
        <div class="flex justify-end gap-2 pt-2">
            <TmButton Variant="ButtonVariant.Ghost" OnClick="() => _showCustomModal = false">Close</TmButton>
            <TmButton Variant="ButtonVariant.Primary" OnClick="() => { _showCustomModal = false; }">Got it!</TmButton>
        </div>
    </div>
</TmModal>

@code {
    // Basic Modal
    private bool _showBasicModal;
    
    // Sized Modal
    private bool _showSizedModal;
    private ModalSize _modalSize = ModalSize.Medium;
    
    // Alert Dialog
    private bool _showAlert;
    private DialogVariant _alertVariant = DialogVariant.Info;
    private string _alertTitle = "Information";
    private string _alertMessage = "This is an alert message.";
    
    // Confirm Dialog
    private bool _showConfirm;
    private bool _confirmIsDangerous;
    private string _confirmTitle = "Confirm Action";
    private string _confirmMessage = "Are you sure you want to proceed?";
    private bool? _confirmResult;
    
    // Prompt Dialog
    private bool _showPrompt;
    private string? _promptResult;
    
    // Custom Modal
    private bool _showCustomModal;
    
    private void ShowAlert(DialogVariant variant)
    {
        _alertVariant = variant;
        _alertTitle = variant switch
        {
            DialogVariant.Success => "Success!",
            DialogVariant.Warning => "Warning",
            DialogVariant.Error => "Error",
            _ => "Information"
        };
        _alertMessage = variant switch
        {
            DialogVariant.Success => "Your operation was completed successfully.",
            DialogVariant.Warning => "Please review your settings before continuing.",
            DialogVariant.Error => "Something went wrong. Please try again.",
            _ => "Here is some information you should know."
        };
        _showAlert = true;
    }
    
    private void OnAlertResult(bool? result)
    {
        _showAlert = false;
    }
    
    private void ShowConfirm()
    {
        _confirmIsDangerous = false;
        _confirmTitle = "Confirm Action";
        _confirmMessage = "Are you sure you want to proceed with this action?";
        _showConfirm = true;
    }
    
    private void ShowDangerConfirm()
    {
        _confirmIsDangerous = true;
        _confirmTitle = "Delete Item?";
        _confirmMessage = "This action cannot be undone. The item will be permanently deleted.";
        _showConfirm = true;
    }
    
    private void OnConfirmResult(bool? result)
    {
        _showConfirm = false;
        _confirmResult = result;
    }
    
    private void ShowPrompt()
    {
        _promptResult = null;
        _showPrompt = true;
    }
    
    private void OnPromptResult(string? result)
    {
        _showPrompt = false;
        _promptResult = result;
    }
}
