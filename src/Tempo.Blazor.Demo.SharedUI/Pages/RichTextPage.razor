@page "/richtext"
@using Tempo.Blazor.Components.Activity
@using Tempo.Blazor.Components.Feedback
@using Tempo.Blazor.Components.Inputs
@using System.Net.Http.Json
@using Tempo.Blazor.Demo.Shared
@using Tempo.Blazor.Interfaces
@inject IHttpClientFactory HttpFactory
<PageTitle>Rich Text Editor – Tempo.Blazor</PageTitle>

<!-- Page Header -->
<div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Rich Text Editor</h1>
    <p class="text-slate-600 dark:text-slate-400">Rich text editing with formatting, mentions, emojis, and more.</p>
</div>

<!-- Simple Editor -->
<section class="demo-section">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Simple Editor</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">Basic formatting with lists, tasks, and emojis</p>
        </div>
        <span class="px-2 py-0.5 text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-full">Basic</span>
    </div>
    
    <div class="showcase-card">
        <TmRichEditorSimple 
            @ref="_simpleEditor"
            @bind-Value="_simpleValue"
            Placeholder="Type something with **bold**, _italic_, or lists..."
            MaxLength="500"
            SupportsMentions="true"
            MentionProvider="_mentionProvider"
            OnSubmit="OnSimpleSubmit" />
        
        <div class="mt-4 flex items-center justify-between">
            <div class="flex items-center space-x-2">
                <TmButton Variant="ButtonVariant.Primary" Size="ButtonSize.Sm" OnClick="OnSimpleSubmit">Submit</TmButton>
                <TmButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" OnClick="ClearSimple">Clear</TmButton>
            </div>
            <span class="text-xs text-slate-500">Ctrl+Enter to submit</span>
        </div>
        
        @if (!string.IsNullOrEmpty(_simpleSubmitted))
        {
            <div class="mt-4 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl">
                <p class="text-sm font-medium text-green-800 dark:text-green-200 mb-2">Submitted Content:</p>
                <div class="p-3 bg-white dark:bg-slate-800 rounded-lg border border-green-200 dark:border-green-800">
                    <div class="prose dark:prose-invert max-w-none">@((MarkupString)_simpleSubmitted)</div>
                </div>
            </div>
        }
    </div>
</section>

<!-- Full Editor -->
<section class="demo-section">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Full Editor</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">Complete formatting with headings, tables, images, and more</p>
        </div>
        <span class="px-2 py-0.5 text-xs font-medium bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 rounded-full">Advanced</span>
    </div>
    
    <div class="showcase-card">
        <TmRichEditorFull 
            @ref="_fullEditor"
            @bind-Value="_fullValue"
            Placeholder="Create rich content with headings, lists, and links..."
            Height="400px"
            MaxLength="2000"
            ShowWordCount="true"
            SupportsMentions="true"
            MentionProvider="_mentionProvider"
            SupportsImages="true"
            SupportsTables="true"
            SupportsCodeBlocks="true"
            SupportsBlockquotes="true" />
        
        <div class="mt-4 flex items-center justify-between">
            <div class="flex items-center space-x-2">
                <TmButton Variant="ButtonVariant.Primary" Size="ButtonSize.Sm" OnClick="ShowHtml">Show HTML</TmButton>
                <TmButton Variant="ButtonVariant.Secondary" Size="ButtonSize.Sm" OnClick="PreviewContent">Preview</TmButton>
                <TmButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" OnClick="ClearFull">Clear</TmButton>
            </div>
        </div>
        
        @if (!string.IsNullOrEmpty(_htmlPreview))
        {
            <div class="mt-4 p-4 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl">
                <p class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">HTML Output:</p>
                <pre class="p-3 bg-slate-100 dark:bg-slate-900 rounded-lg text-xs overflow-x-auto text-slate-800 dark:text-slate-200"><code>@_htmlPreview</code></pre>
            </div>
        }
        
        @if (!string.IsNullOrEmpty(_contentPreview))
        {
            <div class="mt-4 p-4 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl">
                <p class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Rendered Preview:</p>
                <div class="p-4 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 prose dark:prose-invert max-w-none">
                    @((MarkupString)_contentPreview)
                </div>
            </div>
        }
    </div>
</section>

<!-- Editor with Tokens (Grouped by Category) -->
<section class="demo-section">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Tokens with Category Grouping</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">Tokens with <code>Category</code> are automatically grouped into sections with sticky headers</p>
        </div>
        <span class="px-2 py-0.5 text-xs font-medium bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-full">Grouped</span>
    </div>

    <div class="showcase-card">
        <TmRichEditorFull
            @ref="_tokenEditor"
            @bind-Value="_tokenValue"
            Placeholder="Type {{ to insert a token, or use the {x} button in toolbar..."
            Height="300px"
            MaxLength="2000"
            ShowWordCount="true"
            SupportsMentions="true"
            MentionProvider="_mentionProvider"
            SupportsTokens="true"
            TokenProvider="_tokenProvider"
            OnTokenInserted="OnTokenInserted"
            OnTokenCreateRequested="OnTokenCreateRequested" />

        <div class="mt-4 flex items-center justify-between">
            <div class="flex items-center space-x-2">
                <TmButton Variant="ButtonVariant.Primary" Size="ButtonSize.Sm" OnClick="ShowTokenHtml">Show HTML</TmButton>
                <TmButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" OnClick="ClearTokenEditor">Clear</TmButton>
            </div>
            <span class="text-xs text-slate-500 dark:text-slate-400">Type <kbd class="px-1 py-0.5 bg-slate-100 dark:bg-slate-700 rounded border border-slate-300 dark:border-slate-600 font-mono">@("{{")</kbd> to search tokens</span>
        </div>

        @if (!string.IsNullOrEmpty(_tokenHtmlPreview))
        {
            <div class="mt-4 p-4 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl">
                <p class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">HTML Output:</p>
                <pre class="p-3 bg-slate-100 dark:bg-slate-900 rounded-lg text-xs overflow-x-auto text-slate-800 dark:text-slate-200"><code>@_tokenHtmlPreview</code></pre>
            </div>
        }

        @if (_lastInsertedToken is not null)
        {
            <div class="mt-4 p-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl flex items-center space-x-2">
                <span class="text-amber-600 dark:text-amber-400 text-sm font-medium">Last inserted:</span>
                <code class="px-2 py-0.5 bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-200 rounded text-xs font-mono">@_lastInsertedToken</code>
            </div>
        }

        @if (_tokenCreateRequested is not null)
        {
            <div class="mt-4 p-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl flex items-center space-x-2">
                <span class="text-green-600 dark:text-green-400 text-sm font-medium">Create requested:</span>
                <code class="px-2 py-0.5 bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-200 rounded text-xs font-mono">@_tokenCreateRequested</code>
            </div>
        }

        <TmModal Show="_showCreateTokenDialog"
                 Title="Vytvořit novou proměnnou"
                 Size="ModalSize.Small"
                 ShowDefaultFooterButtons="true"
                 OkButtonText="Vytvořit a vložit"
                 CancelButtonText="Zrušit"
                 OkButtonDisabled="@string.IsNullOrWhiteSpace(_newTokenKey)"
                 OnOk="OnCreateTokenConfirm"
                 OnClose="OnCreateTokenCancel">
            <div class="space-y-4">
                <TmTextInput Label="Klíč (key)"
                             Placeholder="např. user.phone"
                             @bind-Value="_newTokenKey" />
                <TmTextInput Label="Zobrazovaný název"
                             Placeholder="např. Telefon uživatele"
                             @bind-Value="_newTokenDisplayName" />
                <TmTextInput Label="Popis"
                             Placeholder="např. Telefonní číslo uživatele"
                             @bind-Value="_newTokenDescription" />
                <TmTextInput Label="Kategorie"
                             Placeholder="např. Uživatel"
                             @bind-Value="_newTokenCategory" />
            </div>
        </TmModal>

        <div class="mt-4 p-3 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl">
            <p class="text-xs text-slate-500 dark:text-slate-400">
                API returns tokens with <code class="text-amber-600 dark:text-amber-400">Category</code> (Uživatel, Systém, Dokument, Organizace) — dropdown groups them into sections with sticky headers.
            </p>
        </div>
    </div>
</section>

<!-- Editor with Tokens (Flat / No Categories) -->
<section class="demo-section">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Tokens without Categories (Flat List)</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">When tokens have no <code>Category</code>, the dropdown displays a simple flat list</p>
        </div>
        <span class="px-2 py-0.5 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded-full">Flat</span>
    </div>

    <div class="showcase-card">
        <TmRichEditorSimple
            @ref="_flatTokenEditor"
            @bind-Value="_flatTokenValue"
            Placeholder="Type {{ to see a flat token list..."
            MaxLength="500"
            SupportsTokens="true"
            TokenProvider="_flatTokenProvider" />

        <div class="mt-4 p-3 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl">
            <p class="text-xs text-slate-500 dark:text-slate-400">
                This provider returns tokens without <code class="text-amber-600 dark:text-amber-400">Category</code> — dropdown shows a flat list with no section headers.
            </p>
        </div>
    </div>
</section>

