@code {
    private TmRichEditorSimple? _simpleEditor;
    private TmRichEditorFull? _fullEditor;
    private TmRichEditorFull? _tokenEditor;
    private TmRichEditorSimple? _flatTokenEditor;
    private string _simpleValue = string.Empty;
    private string _fullValue = string.Empty;
    private string _tokenValue = string.Empty;
    private string _flatTokenValue = string.Empty;
    private string _simpleSubmitted = string.Empty;
    private string _htmlPreview = string.Empty;
    private string _contentPreview = string.Empty;
    private string _tokenHtmlPreview = string.Empty;
    private string? _lastInsertedToken;
    private string? _tokenCreateRequested;
    private bool _showCreateTokenDialog;
    private string _newTokenKey = string.Empty;
    private string _newTokenDisplayName = string.Empty;
    private string _newTokenDescription = string.Empty;
    private string _newTokenCategory = string.Empty;

    private ApiMentionProvider? _mentionProvider;
    private ApiTokenProvider? _tokenProvider;
    private FlatTokenProvider? _flatTokenProvider;

    protected override void OnInitialized()
    {
        var http = HttpFactory.CreateClient("DemoApi");
        _mentionProvider = new ApiMentionProvider(http);
        _tokenProvider = new ApiTokenProvider(http);
        _flatTokenProvider = new FlatTokenProvider();
    }

    private async Task OnSimpleSubmit()
    {
        if (_simpleEditor != null)
        {
            _simpleSubmitted = _simpleEditor.GetHtml();
            await _simpleEditor.Clear();
        }
    }

    private async Task ClearSimple()
    {
        if (_simpleEditor != null)
        {
            await _simpleEditor.Clear();
        }
        _simpleSubmitted = string.Empty;
    }

    private async Task ShowHtml()
    {
        // Get current value from editor if available
        if (_fullEditor != null)
        {
            _fullValue = _fullEditor.GetHtml();
        }
        _htmlPreview = _fullValue;
        _contentPreview = string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    private async Task PreviewContent()
    {
        // Get current value from editor if available
        if (_fullEditor != null)
        {
            _fullValue = _fullEditor.GetHtml();
        }
        _contentPreview = _fullValue;
        _htmlPreview = string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ClearFull()
    {
        if (_fullEditor != null)
        {
            await _fullEditor.Clear();
        }
        _htmlPreview = string.Empty;
        _contentPreview = string.Empty;
    }

    private async Task ShowTokenHtml()
    {
        if (_tokenEditor != null)
        {
            _tokenValue = _tokenEditor.GetHtml();
        }
        _tokenHtmlPreview = _tokenValue;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ClearTokenEditor()
    {
        if (_tokenEditor != null)
        {
            await _tokenEditor.Clear();
        }
        _tokenHtmlPreview = string.Empty;
        _lastInsertedToken = null;
        _tokenCreateRequested = null;
    }

    private void OnTokenInserted(IToken token)
    {
        _lastInsertedToken = $"{token.Key} ({token.DisplayName})";
        StateHasChanged();
    }

    private void OnTokenCreateRequested(string? query)
    {
        _tokenCreateRequested = query ?? "(empty)";
        _newTokenKey = query ?? string.Empty;
        _newTokenDisplayName = query ?? string.Empty;
        _showCreateTokenDialog = true;
        StateHasChanged();
    }

    private async Task OnCreateTokenConfirm()
    {
        if (string.IsNullOrWhiteSpace(_newTokenKey)) return;

        _showCreateTokenDialog = false;

        // Save the new token to the API
        try
        {
            var http = HttpFactory.CreateClient("DemoApi");
            var dto = new TokenDto(
                _newTokenKey,
                string.IsNullOrWhiteSpace(_newTokenDisplayName) ? _newTokenKey : _newTokenDisplayName,
                string.IsNullOrWhiteSpace(_newTokenDescription) ? null : _newTokenDescription,
                string.IsNullOrWhiteSpace(_newTokenCategory) ? null : _newTokenCategory);
            await http.PostAsJsonAsync("api/tokens", dto);
        }
        catch { /* API not available */ }

        // Refresh token list in the editor so the new token appears in autocomplete
        if (_tokenEditor != null)
        {
            await _tokenEditor.RefreshTokensAsync();
            await _tokenEditor.InsertTokenAsync(_newTokenKey,
                string.IsNullOrWhiteSpace(_newTokenDisplayName) ? _newTokenKey : _newTokenDisplayName);
        }

        _newTokenKey = string.Empty;
        _newTokenDisplayName = string.Empty;
        _newTokenDescription = string.Empty;
        _newTokenCategory = string.Empty;
    }

    private void OnCreateTokenCancel()
    {
        _showCreateTokenDialog = false;
        _newTokenKey = string.Empty;
        _newTokenDisplayName = string.Empty;
        _newTokenDescription = string.Empty;
        _newTokenCategory = string.Empty;
    }

    /// <summary>
    /// API-based token provider for the demo.
    /// </summary>
    private class ApiTokenProvider : ITokenDataProvider
    {
        private readonly HttpClient _http;

        public ApiTokenProvider(HttpClient http)
        {
            _http = http;
        }

        public bool SupportsCreation => true;

        public void Refresh() { }

        public async Task<IEnumerable<IToken>> SearchTokensAsync(string query, CancellationToken cancellationToken = default)
        {
            try
            {
                var response = await _http.GetFromJsonAsync<List<TokenDto>>(
                    $"api/tokens/search?q={Uri.EscapeDataString(query)}&limit=100",
                    cancellationToken);

                if (response == null) return Array.Empty<IToken>();

                return response.Select(t => new TokenAdapter(t)).ToList();
            }
            catch
            {
                return Array.Empty<IToken>();
            }
        }
    }

    /// <summary>
    /// Adapter to convert TokenDto to IToken.
    /// </summary>
    private class TokenAdapter : IToken
    {
        private readonly TokenDto _token;

        public TokenAdapter(TokenDto token)
        {
            _token = token;
        }

        public string Key => _token.Key;
        public string DisplayName => _token.DisplayName;
        public string? Description => _token.Description;
        public string? Category => _token.Category;
    }

    /// <summary>
    /// API-based mention provider for the demo.
    /// </summary>
    private class ApiMentionProvider : IMentionDataProvider
    {
        private readonly HttpClient _http;

        public ApiMentionProvider(HttpClient http)
        {
            _http = http;
        }

        public async Task<IEnumerable<IMentionUser>> SearchUsersAsync(string query, CancellationToken cancellationToken = default)
        {
            try
            {
                var response = await _http.GetFromJsonAsync<List<UserDto>>(
                    $"api/users/search?q={Uri.EscapeDataString(query)}&limit=8", 
                    cancellationToken);
                
                if (response == null) return Array.Empty<IMentionUser>();
                
                return response.Select(u => new MentionUserAdapter(u)).ToList();
            }
            catch
            {
                return Array.Empty<IMentionUser>();
            }
        }
    }

    /// <summary>
    /// Adapter to convert UserDto to IMentionUser.
    /// </summary>
    private class MentionUserAdapter : IMentionUser
    {
        private readonly UserDto _user;

        public MentionUserAdapter(UserDto user)
        {
            _user = user;
        }

        public string Id => _user.Id;
        public string UserName => _user.UserName;
        public string DisplayName => _user.DisplayName;
        public string? AvatarUrl => _user.AvatarUrl;
    }

    /// <summary>
    /// In-memory token provider without categories (flat list demo).
    /// </summary>
    private class FlatTokenProvider : ITokenDataProvider
    {
        private static readonly FlatToken[] _tokens =
        [
            new("today", "Dnešní datum", "Aktuální datum ve formátu dd.MM.yyyy"),
            new("now", "Aktuální čas", "Čas ve formátu HH:mm:ss"),
            new("fullname", "Celé jméno", "Jméno a příjmení přihlášeného uživatele"),
            new("email", "E-mail", "E-mailová adresa uživatele"),
            new("company", "Firma", "Název společnosti"),
        ];

        public bool SupportsCreation => false;

        public void Refresh() { }

        public Task<IEnumerable<IToken>> SearchTokensAsync(string query, CancellationToken cancellationToken = default)
        {
            IEnumerable<IToken> result = string.IsNullOrWhiteSpace(query)
                ? _tokens
                : _tokens.Where(t =>
                    t.Key.Contains(query, StringComparison.OrdinalIgnoreCase) ||
                    t.DisplayName.Contains(query, StringComparison.OrdinalIgnoreCase));
            return Task.FromResult(result);
        }

        private record FlatToken(string Key, string DisplayName, string? Description) : IToken
        {
            public string? Category => null;
        }
    }
}
