@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject Tempo.Blazor.Services.ThemeService ThemeService

<div class="min-h-screen bg-slate-50 dark:bg-slate-950 transition-colors duration-300 @(ThemeService.IsDark ? "dark" : "")" data-theme="@ThemeService.ThemeName">
    <!-- Mobile Header -->
    <div class="lg:hidden fixed top-0 left-0 right-0 z-40 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800">
        <div class="flex items-center justify-between px-4 py-3">
            <div class="flex items-center space-x-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary-500 to-primary-700 flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <span class="font-bold text-lg text-slate-800 dark:text-slate-100">Tempo.Blazor</span>
            </div>
            <div class="flex items-center space-x-2">
                <ThemeToggle />
                <button @onclick="ToggleMobileMenu" class="p-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        @if (_mobileMenuOpen)
                        {
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        }
                        else
                        {
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        }
                    </svg>
                </button>
            </div>
        </div>
        
        <!-- Mobile Menu -->
        @if (_mobileMenuOpen)
        {
            <div class="border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50">
                <NavMenu IsMobile="true" />
            </div>
        }
    </div>

    <div class="flex min-h-screen pt-16 lg:pt-0 overflow-x-hidden">
        <!-- Sidebar (Desktop) -->
        <aside class="hidden lg:flex w-72 flex-col fixed inset-y-0 left-0 z-30 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 overflow-hidden">
            <!-- Logo -->
            <div class="flex items-center space-x-3 px-6 py-5 border-b border-slate-200 dark:border-slate-800">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary-500 to-primary-700 flex items-center justify-center shadow-lg shadow-primary-500/25">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <div>
                    <span class="font-bold text-xl text-slate-800 dark:text-slate-100">Tempo.Blazor</span>
                    <p class="text-xs text-slate-500 dark:text-slate-400">Component Library</p>
                </div>
            </div>

            <!-- Navigation -->
            <div class="flex-1 overflow-y-auto py-4 px-3">
                <NavMenu />
            </div>

            <!-- Footer -->
            <div class="p-4 border-t border-slate-200 dark:border-slate-800">
                <div class="flex items-center justify-between">
                    <LanguageSwitcher />
                    <ThemeToggle />
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 lg:ml-[18.5rem]">
            <!-- Top Bar -->
            <div class="sticky top-0 z-30 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl border-b border-slate-200 dark:border-slate-800">
                <div class="flex items-center justify-between px-4 sm:px-6 lg:px-8 py-4">
                    <!-- Breadcrumb / Page Title -->
                    <div class="flex items-center space-x-2 text-sm text-slate-500 dark:text-slate-400">
                        <span class="hidden sm:inline">Tempo.Blazor</span>
                        <svg class="hidden sm:inline w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                        <span class="font-medium text-slate-800 dark:text-slate-200">Demo</span>
                    </div>

                    <!-- Right Actions -->
                    <div class="flex items-center space-x-4">
                        <a href="https://github.com/tempo/blazor" target="_blank" 
                           class="hidden sm:flex items-center space-x-2 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                            </svg>
                            <span>GitHub</span>
                        </a>
                        <a href="https://learn.microsoft.com/aspnet/core/" target="_blank" 
                           class="px-4 py-2 rounded-lg text-sm font-medium bg-primary-600 hover:bg-primary-700 text-white transition-colors shadow-lg shadow-primary-600/25">
                            Documentation
                        </a>
                    </div>
                </div>
            </div>

            <!-- Page Content -->
            <div class="px-4 sm:px-6 lg:px-8 py-8">
                <div class="max-w-7xl mx-auto animate-fade-in">
                    @Body
                </div>
            </div>
        </main>
    </div>

    <!-- Toast Notifications -->
    <TmToastContainer Position="ToastPosition.TopRight" MaxVisible="5" />
</div>

@code {
    private bool _mobileMenuOpen = false;
    private readonly string _currentCulture =
        System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;

    protected override void OnInitialized()
    {
        ThemeService.OnChanged += StateHasChanged;
    }

    private void ToggleMobileMenu()
    {
        _mobileMenuOpen = !_mobileMenuOpen;
    }

    public void Dispose()
    {
        ThemeService.OnChanged -= StateHasChanged;
    }
}
