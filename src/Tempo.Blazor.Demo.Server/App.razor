<Router AppAssembly="@typeof(App).Assembly" AdditionalAssemblies="new[] { typeof(Tempo.Blazor.Demo.SharedUI.Pages.Home).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(Tempo.Blazor.Demo.SharedUI.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(Tempo.Blazor.Demo.SharedUI.Layout.MainLayout)">
            <Tempo.Blazor.Demo.SharedUI.Pages.NotFound />
        </LayoutView>
    </NotFound>
</Router>
