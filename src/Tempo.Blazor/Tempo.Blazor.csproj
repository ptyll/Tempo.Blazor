<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>

    <!-- NuGet Package Metadata -->
    <IsPackable>true</IsPackable>
    <PackageId>Tempo.Blazor</PackageId>
    <Version>1.0.0</Version>
    <Authors>ptyll</Authors>
    <Description>Comprehensive Blazor component library with 100+ components. Supports WebAssembly, Server, and InteractiveAuto render modes. Multi-targets .NET 8/9/10. Includes FluentValidation integration, multilingual support (EN/CS), CSS variable theming, and dark mode.</Description>
    <PackageTags>blazor;components;ui;server;wasm;interactive-auto;fluentvalidation;localization</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryType>git</RepositoryType>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="FluentValidation" Version="12.1.1" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="8.0.12" />
    <PackageReference Include="Microsoft.Extensions.Localization" Version="8.0.12" />
    <PackageReference Include="Microsoft.Extensions.Localization.Abstractions" Version="8.0.12" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0'">
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="9.0.3" />
    <PackageReference Include="Microsoft.Extensions.Localization" Version="9.0.3" />
    <PackageReference Include="Microsoft.Extensions.Localization.Abstractions" Version="9.0.3" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.3" />
    <PackageReference Include="Microsoft.Extensions.Localization" Version="10.0.3" />
    <PackageReference Include="Microsoft.Extensions.Localization.Abstractions" Version="10.0.3" />
  </ItemGroup>

  <!-- Include README in NuGet package -->
  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" Condition="Exists('..\..\README.md')" />
    <None Include="AGENT.md" Pack="true" PackagePath="\" Condition="Exists('AGENT.md')" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Tempo.Blazor.Abstractions\Tempo.Blazor.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Tempo.Blazor.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <!-- ═══ CSS Bundling: merge all @imports into a single file ═══ -->

  <ItemGroup>
    <CssBundleInputs Include="wwwroot\css\**\*.css" Exclude="wwwroot\css\tempo-blazor.bundled.css" />
  </ItemGroup>

  <UsingTask TaskName="BundleCss" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <InputFile ParameterType="System.String" Required="true" />
      <OutputFile ParameterType="System.String" Required="true" />
      <Minify ParameterType="System.Boolean" Required="false" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Text.RegularExpressions" />
      <Code Type="Fragment" Language="cs"><![CDATA[
try
{
    var content = File.ReadAllText(InputFile, System.Text.Encoding.UTF8);
    var baseDir = Path.GetDirectoryName(InputFile);
    var importRegex = new Regex(@"@import\s+[""']([^""']+)[""']\s*;");

    content = importRegex.Replace(content, match =>
    {
        var relativePath = match.Groups[1].Value;
        var fullPath = Path.GetFullPath(Path.Combine(baseDir, relativePath));
        if (File.Exists(fullPath))
        {
            var imported = File.ReadAllText(fullPath, System.Text.Encoding.UTF8);
            return "/* === " + relativePath + " === */\n" + imported;
        }
        Log.LogWarning("CSS import not found: " + fullPath);
        return match.Value;
    });

    if (Minify)
    {
        // Remove CSS comments (but not inside content: "..." strings)
        content = Regex.Replace(content, @"/\*[\s\S]*?\*/", "");
        // Collapse runs of whitespace to single space
        content = Regex.Replace(content, @"\s+", " ");
        // Remove space around structural characters
        content = Regex.Replace(content, @"\s*([{};:,>~+])\s*", "$1");
        // Restore newline after } for minimal readability
        content = content.Replace("}", "}\n");
        content = content.Trim();
    }

    Directory.CreateDirectory(Path.GetDirectoryName(OutputFile));
    File.WriteAllText(OutputFile, content, System.Text.Encoding.UTF8);
    Log.LogMessage(Microsoft.Build.Framework.MessageImportance.High,
        "CSS bundle created: " + OutputFile + " (" + content.Length + " bytes)");
}
catch (Exception ex)
{
    Log.LogError("BundleCss failed: " + ex.Message);
}
      ]]></Code>
    </Task>
  </UsingTask>

  <Target Name="BundleCssFiles"
          BeforeTargets="ResolveProjectStaticWebAssets"
          Inputs="wwwroot\css\tempo-blazor.css;@(CssBundleInputs)"
          Outputs="wwwroot\css\tempo-blazor.bundled.css">
    <BundleCss
      InputFile="$(MSBuildProjectDirectory)\wwwroot\css\tempo-blazor.css"
      OutputFile="$(MSBuildProjectDirectory)\wwwroot\css\tempo-blazor.bundled.css"
      Minify="true" />
  </Target>

  <Target Name="CleanBundledCss" BeforeTargets="Clean">
    <Delete Files="wwwroot\css\tempo-blazor.bundled.css" />
  </Target>

</Project>
