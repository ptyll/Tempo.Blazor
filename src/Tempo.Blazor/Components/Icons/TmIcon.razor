@namespace Tempo.Blazor.Components.Icons

@if (_resolvedSvg is not null)
{
    <svg @attributes="AdditionalAttributes"
         class="@CssClass"
         viewBox="0 0 24 24"
         fill="none"
         stroke="currentColor"
         stroke-width="@StrokeWidth.ToString(System.Globalization.CultureInfo.InvariantCulture)"
         stroke-linecap="round"
         stroke-linejoin="round"
         aria-hidden="true"
         focusable="false">
        @((MarkupString)_resolvedSvg)
    </svg>
}
else
{
    <span class="tm-icon-unknown" aria-hidden="true"></span>
}

@code {
    /// <summary>Icon name — use IconNames constants (e.g. IconNames.Check).</summary>
    [Parameter, EditorRequired] public string Name { get; set; } = string.Empty;

    /// <summary>Display size of the icon.</summary>
    [Parameter] public IconSize Size { get; set; } = IconSize.Md;

    /// <summary>Color variant of the icon. Default inherits from parent (currentColor).</summary>
    [Parameter] public IconColor Color { get; set; } = IconColor.Current;

    /// <summary>SVG stroke-width. Default is 2.</summary>
    [Parameter] public double StrokeWidth { get; set; } = 2;

    /// <summary>Additional HTML attributes passed to the svg element.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    // Resolved SVG content: built-in path, registry content, or null (= fallback span)
    private string? _resolvedSvg;

    protected override void OnParametersSet()
    {
        var builtIn = GetBuiltInPath(Name);
        if (!string.IsNullOrEmpty(builtIn))
        {
            _resolvedSvg = builtIn;
            return;
        }

        // Fallback 1: custom IconRegistry (direct dict or registered providers)
        var registered = IconRegistry.Resolve(Name);
        if (registered is not null)
        {
            _resolvedSvg = registered;
            return;
        }

        // Fallback 2: render <span class="tm-icon-unknown">
        _resolvedSvg = null;
    }

    private string CssClass
    {
        get
        {
            var sizeClass = Size switch
            {
                IconSize.Xs => "tm-icon-xs",
                IconSize.Sm => "tm-icon-sm",
                IconSize.Md => "tm-icon-md",
                IconSize.Lg => "tm-icon-lg",
                IconSize.Xl => "tm-icon-xl",
                _           => "tm-icon-md"
            };
            var colorClass = Color switch
            {
                IconColor.Primary => "tm-icon-primary",
                IconColor.Danger  => "tm-icon-danger",
                IconColor.Success => "tm-icon-success",
                IconColor.Warning => "tm-icon-warning",
                IconColor.Muted   => "tm-icon-muted",
                _                 => "tm-icon-current"
            };
            return $"tm-icon {sizeClass} {colorClass}";
        }
    }

