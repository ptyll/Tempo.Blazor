@namespace Tempo.Blazor.Components.Scheduler
@using Tempo.Blazor.Models
@using System.Globalization
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="tm-scheduler-timeline" @ref="_containerRef" data-slot-duration="@SlotDuration">
    @* Header: time columns *@
    <div class="tm-scheduler-timeline-header">
        <div class="tm-scheduler-timeline-resource-header"></div>
        @for (var hour = 0; hour < 24; hour++)
        {
            var h = hour;
            <div class="tm-scheduler-timeline-time-header">@h.ToString("D2"):00</div>
        }
    </div>

    @* Resource rows *@
    @foreach (var resource in _resources)
    {
        var r = resource;
        var rowEvents = GetEventsForResource(r.Id);

        <div class="tm-scheduler-timeline-row" data-resource="@r.Id">
            <div class="tm-scheduler-timeline-resource-label"
                 style="@(r.Color is not null ? $"border-left-color: {r.Color};" : "")">
                @r.Name
            </div>
            <div class="tm-scheduler-timeline-row-body">
                @* Slots *@
                @for (var slotIndex = 0; slotIndex < _slotsPerDay; slotIndex++)
                {
                    var si = slotIndex;
                    var slotStart = CurrentDate.Date.AddMinutes(si * SlotDuration);
                    var slotEnd = slotStart.AddMinutes(SlotDuration);
                     <div class="tm-scheduler-timeline-slot"
                          style="left: @F(GetMinuteLeftPercent(si * SlotDuration))%; width: @F(GetSlotWidthPercent())%;"
                          @ondrop="@(() => HandleSlotDrop(slotStart, slotEnd, r.Id))"
                          @ondragover:preventDefault="true"
                          @onclick="@(() => OnSlotClick.InvokeAsync((slotStart, slotEnd)))"
                          @oncontextmenu="@(e => HandleSlotContextMenu(e, slotStart, slotEnd, r.Id))"
                          @oncontextmenu:preventDefault="true"></div>
                }

                @* Events *@
                @foreach (var evt in rowEvents)
                {
                    var e = evt;
                    var leftPct = GetMinuteLeftPercent(GetEventStartMinutes(e));
                    var widthPct = GetEventWidthPercent(e);

                    <div class="tm-scheduler-timeline-event @e.CssClass"
                         style="left: @F(leftPct)%; width: @F(widthPct)%; --event-color: @(e.Color ?? r.Color ?? "var(--tm-color-primary, #3b82f6)");"
                         title="@e.Title"
                         data-event-id="@e.Id"
                         draggable="@(!ReadOnly && !e.IsReadOnly ? "true" : "false")"
                         @ondragstart="@(() => HandleDragStart(e, r.Id))"
                         @onclick="@(() => OnEventClick.InvokeAsync(e))"
                         @onclick:stopPropagation="true"
                         @oncontextmenu="@(e => HandleEventContextMenu(e, evt))"
                         @oncontextmenu:stopPropagation="true">
                        <span class="tm-scheduler-timeline-event-title">@e.Title</span>
                        @if (!ReadOnly && !e.IsReadOnly)
                        {
                            <div class="tm-scheduler-event-resize-handle tm-scheduler-event-resize-handle--left"
                                 draggable="false"
                                 data-resize-edge="left"
                                 ondragstart="event.preventDefault(); event.stopPropagation();"></div>
                            <div class="tm-scheduler-event-resize-handle tm-scheduler-event-resize-handle--right"
                                 draggable="false"
                                 data-resize-edge="right"
                                 ondragstart="event.preventDefault(); event.stopPropagation();"></div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private DotNetObjectReference<TmSchedulerTimelineView>? _dotNetRef;
    private bool _jsRegistered;
    private ElementReference _containerRef;

    private int _slotsPerDay;
    private List<TmScheduleResource> _resources = [];
    private Dictionary<string, List<TmScheduleEvent>> _resourceEventMap = new();
    private TmScheduleEvent? _draggedEvent;
    private string? _draggedEventOriginalResourceId;

    /// <summary>Currently displayed date.</summary>
    [Parameter] public DateTime CurrentDate { get; set; }

    /// <summary>Resources to display as rows.</summary>
    [Parameter] public IReadOnlyList<TmScheduleResource>? Resources { get; set; }

    /// <summary>Events to display.</summary>
    [Parameter] public IReadOnlyList<TmScheduleEvent>? Events { get; set; }

    /// <summary>Duration of each time slot in minutes.</summary>
    [Parameter] public int SlotDuration { get; set; } = 30;

    /// <summary>Fires when a time slot is clicked.</summary>
    [Parameter] public EventCallback<(DateTime Start, DateTime End)> OnSlotClick { get; set; }

    /// <summary>Fires when an event is clicked.</summary>
    [Parameter] public EventCallback<TmScheduleEvent> OnEventClick { get; set; }

    /// <summary>Whether events are read-only.</summary>
    [Parameter] public bool ReadOnly { get; set; }

    /// <summary>Fires when an event changes.</summary>
    [Parameter] public EventCallback<TmScheduleEvent> OnEventChanged { get; set; }

    /// <summary>Fires when right-clicking on a time slot.</summary>
    [Parameter] public EventCallback<SchedulerSlotContext> OnSlotContextMenu { get; set; }

    /// <summary>Fires when right-clicking on an event.</summary>
    [Parameter] public EventCallback<SchedulerEventContext> OnEventContextMenu { get; set; }

    protected override void OnParametersSet()
    {
        _slotsPerDay = 24 * 60 / Math.Max(1, SlotDuration);
        _resources = Resources?.ToList() ?? [new TmScheduleResource { Id = "_default", Name = "" }];
        BuildResourceEventMap();
    }

    private void BuildResourceEventMap()
    {
        _resourceEventMap.Clear();
        if (Events is null) return;

        foreach (var evt in Events)
        {
            var resourceId = evt.ResourceId ?? "_default";
            if (!_resourceEventMap.TryGetValue(resourceId, out var list))
            {
                list = [];
                _resourceEventMap[resourceId] = list;
            }
            list.Add(evt);
        }
    }

    private List<TmScheduleEvent> GetEventsForResource(string resourceId)
        => _resourceEventMap.TryGetValue(resourceId, out var list) ? list : [];

    private static double GetMinuteLeftPercent(int minutes) => minutes / (24.0 * 60) * 100;
    private double GetSlotWidthPercent() => SlotDuration / (24.0 * 60) * 100;

    private int GetEventStartMinutes(TmScheduleEvent evt)
    {
        var dayStart = CurrentDate.Date;
        var minutes = (int)(evt.Start - dayStart).TotalMinutes;
        return Math.Max(0, Math.Min(minutes, 24 * 60));
    }

    private double GetEventWidthPercent(TmScheduleEvent evt)
    {
        var startMin = GetEventStartMinutes(evt);
        var endMin = (int)(evt.End - CurrentDate.Date).TotalMinutes;
        endMin = Math.Max(startMin + 1, Math.Min(endMin, 24 * 60));
        return (endMin - startMin) / (24.0 * 60) * 100;
    }

    private static string F(double value) => value.ToString("F4", CultureInfo.InvariantCulture);

    private async Task HandleSlotContextMenu(MouseEventArgs e, DateTime slotStart, DateTime slotEnd, string resourceId)
    {
        if (OnSlotContextMenu.HasDelegate)
        {
            await OnSlotContextMenu.InvokeAsync(new SchedulerSlotContext
            {
                Start = slotStart,
                End = slotEnd,
                ResourceId = resourceId,
                ClientX = e.ClientX,
                ClientY = e.ClientY
            });
        }
    }

    private async Task HandleEventContextMenu(MouseEventArgs e, TmScheduleEvent evt)
    {
        if (OnEventContextMenu.HasDelegate)
        {
            await OnEventContextMenu.InvokeAsync(new SchedulerEventContext
            {
                Event = evt,
                ClientX = e.ClientX,
                ClientY = e.ClientY
            });
        }
    }

    // ── Drag & Drop ──

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("TempoBlazor.Scheduler.registerInstance", _containerRef, _dotNetRef);
                _jsRegistered = true;
            }
            catch (JSDisconnectedException) { }
            catch (JSException) { }
            catch (InvalidOperationException) { }
            catch (TaskCanceledException) { }
        }
    }

    private void HandleDragStart(TmScheduleEvent evt, string resourceId)
    {
        if (ReadOnly || evt.IsReadOnly) return;
        _draggedEvent = evt;
        _draggedEventOriginalResourceId = resourceId;
    }

    private async Task HandleSlotDrop(DateTime slotStart, DateTime slotEnd, string targetResourceId)
    {
        if (_draggedEvent is null || ReadOnly) return;

        var duration = _draggedEvent.End - _draggedEvent.Start;
        _draggedEvent.Start = slotStart;
        _draggedEvent.End = slotStart + duration;

        // Update resource if changed
        if (_draggedEventOriginalResourceId != targetResourceId)
        {
            _draggedEvent.ResourceId = targetResourceId;
        }

        await OnEventChanged.InvokeAsync(_draggedEvent);
        _draggedEvent = null;
        _draggedEventOriginalResourceId = null;
    }

    // ── Resize ──

    /// <summary>
    /// Handles the completion of a resize operation from JavaScript.
    /// </summary>
    private async Task HandleResizeComplete(string eventId, int deltaMinutes, string resizeEdge = "right")
    {
        if (ReadOnly || string.IsNullOrEmpty(eventId)) return;

        // Find the event being resized
        var evt = Events?.FirstOrDefault(e => e.Id == eventId);
        if (evt is null || evt.IsReadOnly) return;

        if (resizeEdge == "left")
        {
            // Left resize: change start time
            var newStart = evt.Start.AddMinutes(deltaMinutes);
            
            // Ensure minimum duration (don't let start go past end)
            if (newStart >= evt.End.AddMinutes(-SlotDuration))
            {
                newStart = evt.End.AddMinutes(-SlotDuration);
            }
            
            evt.Start = newStart;
        }
        else
        {
            // Right resize: change end time (default)
            evt.End = evt.End.AddMinutes(deltaMinutes);

            // Ensure minimum duration
            if (evt.End <= evt.Start.AddMinutes(SlotDuration))
            {
                evt.End = evt.Start.AddMinutes(SlotDuration);
            }
        }

        // Notify parent about the change
        await OnEventChanged.InvokeAsync(evt);
    }

    /// <summary>
    /// Called by JavaScript when a resize operation is completed.
    /// </summary>
    [JSInvokable]
    public async Task NotifyResizeComplete(string eventId, int deltaMinutes, string resizeEdge = "right")
    {
        await HandleResizeComplete(eventId, deltaMinutes, resizeEdge);
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("TempoBlazor.Scheduler.unregisterInstance", _containerRef);
            }
            catch (JSDisconnectedException) { }
            catch (InvalidOperationException) { }
            catch (TaskCanceledException) { }
        }
        _dotNetRef?.Dispose();
    }
}
