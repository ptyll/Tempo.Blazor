@namespace Tempo.Blazor.Components.Inputs

@if (!string.IsNullOrEmpty(Password))
{
    <div class="tm-password-strength @Class">
        <div class="tm-password-strength-bar">
            <div class="tm-password-strength-fill tm-strength-@Strength"
                 style="width: @(Strength * 100 / 5)%">
            </div>
        </div>
        <div class="tm-password-strength-info">
            <span class="tm-password-strength-text tm-strength-@Strength">
                @GetStrengthText()
            </span>
            <span class="tm-password-strength-hint">
                @GetStrengthHint()
            </span>
        </div>
    </div>
}

@code {
    /// <summary>The password to evaluate.</summary>
    [Parameter] public string Password { get; set; } = "";

    /// <summary>Additional CSS class(es) for the root element.</summary>
    [Parameter] public string? Class { get; set; }

    private static readonly HashSet<string> CommonPasswords = new(StringComparer.OrdinalIgnoreCase)
    {
        "password", "12345678", "123456789", "1234567890", "qwerty", "qwertyui",
        "11111111", "00000000", "password123", "admin123", "letmein", "welcome",
        "monkey", "dragon", "master", "shadow", "sunshine", "princess", "football",
        "baseball", "iloveyou", "trustno1", "abc123", "welcome1", "jesus", "ninja"
    };

    private bool HasUpper => Password.Any(char.IsUpper);
    private bool HasLower => Password.Any(char.IsLower);
    private bool HasDigit => Password.Any(char.IsDigit);
    private bool HasSpecial => Password.Any(c => !char.IsLetterOrDigit(c));

    private int Strength => CalculateStrength();

    private int CalculateStrength()
    {
        if (string.IsNullOrEmpty(Password) || Password.Length < 6)
            return 0;

        if (CommonPasswords.Contains(Password) ||
            CommonPasswords.Any(common => Password.Contains(common, StringComparison.OrdinalIgnoreCase)))
        {
            return Password.Length >= 12 ? 2 : 1;
        }

        int score = 0;
        int categories = 0;

        if (Password.Length >= 8) score++;
        if (Password.Length >= 12) score++;
        if (Password.Length >= 16) score++;

        if (HasUpper) categories++;
        if (HasLower) categories++;
        if (HasDigit) categories++;
        if (HasSpecial) categories++;

        score += categories;

        if (categories >= 4 && Password.Length >= 12) score++;

        if (HasTripleRepetition(Password) || HasObviousSequence(Password))
            score--;

        return Math.Max(0, Math.Min(score, 5));
    }

    private static bool HasTripleRepetition(string password)
    {
        for (int i = 0; i < password.Length - 2; i++)
        {
            if (password[i] == password[i + 1] && password[i] == password[i + 2])
                return true;
        }
        return false;
    }

    private static bool HasObviousSequence(string password)
    {
        string lower = password.ToLower();

        for (int i = 0; i < lower.Length - 2; i++)
        {
            char c1 = lower[i];
            char c2 = lower[i + 1];
            char c3 = lower[i + 2];

            if (c1 >= 'a' && c1 <= 'z' && c2 == c1 + 1 && c3 == c1 + 2)
                return true;

            if (c1 >= '0' && c1 <= '7' && c2 == c1 + 1 && c3 == c1 + 2)
                return true;

            string three = $"{c1}{c2}{c3}";
            if (three is "qwe" or "wer" or "ert" or "rty" or
                "asd" or "sdf" or "dfg" or
                "zxc" or "xcv" or "cvb")
                return true;
        }
        return false;
    }

    private string GetStrengthText()
    {
        return Strength switch
        {
            0 or 1 => Loc["TmPasswordStrength_VeryWeak"],
            2 => Loc["TmPasswordStrength_Weak"],
            3 => Loc["TmPasswordStrength_Medium"],
            4 => Loc["TmPasswordStrength_Strong"],
            _ => Loc["TmPasswordStrength_VeryStrong"]
        };
    }

    private string GetStrengthHint()
    {
        int categories = (HasUpper ? 1 : 0) + (HasLower ? 1 : 0) + (HasDigit ? 1 : 0) + (HasSpecial ? 1 : 0);

        if (Password.Length < 8)
            return Loc["TmPasswordStrength_HintUseAtLeast8Chars"];

        if (categories < 2)
        {
            if (!HasLower && !HasUpper)
                return Loc["TmPasswordStrength_HintAddLetters"];
            if (!HasDigit)
                return Loc["TmPasswordStrength_HintAddNumbers"];
            return Loc["TmPasswordStrength_HintAddSpecialChars"];
        }

        if (categories < 3)
        {
            if (!HasUpper)
                return Loc["TmPasswordStrength_HintAddUppercase"];
            if (!HasDigit)
                return Loc["TmPasswordStrength_HintAddNumbers"];
            return Loc["TmPasswordStrength_HintAddSpecialChars"];
        }

        if (categories < 4)
        {
            if (!HasSpecial)
                return Loc["TmPasswordStrength_HintAddSpecialChars"];
            if (!HasDigit)
                return Loc["TmPasswordStrength_HintAddNumbers"];
            if (!HasUpper)
                return Loc["TmPasswordStrength_HintAddUppercase"];
            return Loc["TmPasswordStrength_HintAddLowercase"];
        }

        if (Password.Length < 12)
            return Loc["TmPasswordStrength_HintMakeItLonger"];

        if (HasTripleRepetition(Password))
            return Loc["TmPasswordStrength_HintAvoidCommonPatterns"];

        if (HasObviousSequence(Password))
            return Loc["TmPasswordStrength_HintAvoidCommonPatterns"];

        if (CommonPasswords.Contains(Password) ||
            CommonPasswords.Any(common => Password.Contains(common, StringComparison.OrdinalIgnoreCase)))
            return Loc["TmPasswordStrength_HintAvoidCommonWords"];

        return Loc["TmPasswordStrength_HintExcellent"];
    }
}
