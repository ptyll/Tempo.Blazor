@namespace Tempo.Blazor.Components.Inputs
@using Tempo.Blazor.Components.Icons

<div class="tm-input-wrapper">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label for="@Id" class="tm-input-label">@Label</label>
    }
    <div class="tm-input-container">
        @if (!string.IsNullOrEmpty(LeftIcon))
        {
            <div class="tm-input-left-icon">
                <TmIcon Name="@LeftIcon" Size="IconSize.Sm" />
            </div>
        }
        <input id="@Id"
               type="@Type"
               value="@Value"
               placeholder="@Placeholder"
               disabled="@Disabled"
               readonly="@ReadOnly"
               required="@Required"
               tabindex="@TabIndex"
               autofocus="@AutoFocus"
               class="@InputCssClass"
               @oninput="HandleInputAsync"
               @onchange="HandleChangeAsync"
               @onkeydown="HandleKeyDownAsync"
               @onkeyup="HandleKeyUpAsync"
               @onkeypress="HandleKeyPressAsync"
               @onfocus="HandleFocusAsync"
               @onblur="HandleBlurAsync" />
        @if (ShowValidationIcons)
        {
            @if (IsValid == true)
            {
                <div class="tm-input-validation-icon tm-input-validation-success">
                    <TmIcon Name="@IconNames.CheckCircle" Size="IconSize.Sm" />
                </div>
            }
            else if (IsValid == false)
            {
                <div class="tm-input-validation-icon tm-input-validation-error">
                    <TmIcon Name="@IconNames.AlertCircle" Size="IconSize.Sm" />
                </div>
            }
        }
        else if (!string.IsNullOrEmpty(RightIcon))
        {
            <div class="tm-input-right-icon">
                <TmIcon Name="@RightIcon" Size="IconSize.Sm" />
            </div>
        }
    </div>
    @if (!string.IsNullOrEmpty(Error))
    {
        <div data-testid="error-message" class="tm-input-error-message">
            <TmIcon Name="@IconNames.AlertCircle" Size="IconSize.Xs" />
            <span>@Error</span>
        </div>
    }
    @if (!string.IsNullOrEmpty(HelpText) && string.IsNullOrEmpty(Error))
    {
        <div data-testid="help-text" class="tm-input-help-text">@HelpText</div>
    }
</div>

@code {
    /// <summary>Current text value.</summary>
    [Parameter] public string Value { get; set; } = string.Empty;

    /// <summary>Fires when the value changes.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>Label shown above the input.</summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>Placeholder text.</summary>
    [Parameter] public string? Placeholder { get; set; }

    /// <summary>Validation error message. Shows error styling when set.</summary>
    [Parameter] public string? Error { get; set; }

    /// <summary>Help text shown below the input when no error is present.</summary>
    [Parameter] public string? HelpText { get; set; }

    /// <summary>Icon name for the leading icon slot.</summary>
    [Parameter] public string? LeftIcon { get; set; }

    /// <summary>Icon name for the trailing icon slot.</summary>
    [Parameter] public string? RightIcon { get; set; }

    /// <summary>HTML input type. Defaults to "text".</summary>
    [Parameter] public string Type { get; set; } = "text";

    /// <summary>HTML id attribute. Defaults to a generated unique id.</summary>
    [Parameter] public string Id { get; set; } = Guid.NewGuid().ToString("n")[..8];

    /// <summary>Disables the input.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Makes the input read-only.</summary>
    [Parameter] public bool ReadOnly { get; set; }

    /// <summary>Marks the input as required.</summary>
    [Parameter] public bool Required { get; set; }

    /// <summary>Tab index.</summary>
    [Parameter] public int TabIndex { get; set; } = 0;

    /// <summary>Auto-focuses the input on render.</summary>
    [Parameter] public bool AutoFocus { get; set; }

    /// <summary>When true, shows validation icons (checkmark for valid, error for invalid).</summary>
    [Parameter] public bool ShowValidationIcons { get; set; }

    /// <summary>Validation state: true = valid (green), false = invalid (red), null = neutral.</summary>
    [Parameter] public bool? IsValid { get; set; }

    /// <summary>Additional CSS class(es) to apply to the input element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Fires when a key is pressed down.</summary>
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }

    /// <summary>Fires when a key is released.</summary>
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyUp { get; set; }

    /// <summary>Fires when a key is pressed.</summary>
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyPress { get; set; }

    /// <summary>Fires when the input receives focus.</summary>
    [Parameter] public EventCallback<FocusEventArgs> OnFocus { get; set; }

    /// <summary>Fires when the input loses focus.</summary>
    [Parameter] public EventCallback<FocusEventArgs> OnBlur { get; set; }

    private string InputCssClass
    {
        get
        {
            var baseClass = $"tm-input{(IsValid == true ? " tm-input-valid" : "")}{(IsValid == false || !string.IsNullOrEmpty(Error) ? " tm-input-error" : "")}{(Disabled ? " tm-input-disabled" : "")}{(ReadOnly ? " tm-input-readonly" : "")}{(ShowValidationIcons && IsValid != null ? " tm-input-with-validation-icon" : "")}{(!string.IsNullOrEmpty(LeftIcon) ? " tm-input-with-left-icon" : "")}";
            return string.IsNullOrWhiteSpace(Class) ? baseClass : $"{baseClass} {Class}";
        }
    }

    private async Task HandleInputAsync(ChangeEventArgs e)
        => await ValueChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);

    private async Task HandleChangeAsync(ChangeEventArgs e)
        => await ValueChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
        => await OnKeyDown.InvokeAsync(e);

    private async Task HandleKeyUpAsync(KeyboardEventArgs e)
        => await OnKeyUp.InvokeAsync(e);

    private async Task HandleKeyPressAsync(KeyboardEventArgs e)
        => await OnKeyPress.InvokeAsync(e);

    private async Task HandleFocusAsync(FocusEventArgs e)
        => await OnFocus.InvokeAsync(e);

    private async Task HandleBlurAsync(FocusEventArgs e)
        => await OnBlur.InvokeAsync(e);
}
