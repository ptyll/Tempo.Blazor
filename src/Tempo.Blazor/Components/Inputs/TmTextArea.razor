@namespace Tempo.Blazor.Components.Inputs

<div class="tm-input-wrapper @Class">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label for="@Id" class="tm-input-label">@Label</label>
    }
    <textarea id="@Id"
              placeholder="@Placeholder"
              rows="@Rows"
              maxlength="@MaxLength"
              disabled="@Disabled"
              tabindex="@TabIndex"
              autocomplete="@AutoComplete"
              class="@InputCssClass"
              @attributes="AdditionalAttributes"
              @onchange="HandleOnChange"
              @oninput="HandleOnInput">@Value</textarea>
    @if (!string.IsNullOrEmpty(Error))
    {
        <div data-testid="error-message" class="tm-input-error-message">@Error</div>
    }
</div>

@code {
    /// <summary>Current text value.</summary>
    [Parameter] public string Value { get; set; } = string.Empty;

    /// <summary>Fires when the value changes.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>Label shown above the textarea.</summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>Placeholder text.</summary>
    [Parameter] public string? Placeholder { get; set; }

    /// <summary>Validation error message.</summary>
    [Parameter] public string? Error { get; set; }

    /// <summary>Number of visible rows. Defaults to 3.</summary>
    [Parameter] public int Rows { get; set; } = 3;

    /// <summary>Maximum character count.</summary>
    [Parameter] public int? MaxLength { get; set; }

    /// <summary>Disables the textarea.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Tab index.</summary>
    [Parameter] public int TabIndex { get; set; } = 0;

    /// <summary>HTML id attribute.</summary>
    [Parameter] public string Id { get; set; } = Guid.NewGuid().ToString("n")[..8];

    /// <summary>HTML autocomplete attribute. Common values: "on", "off".</summary>
    [Parameter] public string? AutoComplete { get; set; }

    /// <summary>When true, fires ValueChanged on every keystroke instead of on blur.</summary>
    [Parameter] public bool Immediate { get; set; }

    /// <summary>Additional CSS class(es).</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Additional attributes to be applied to the textarea element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string InputCssClass =>
        $"tm-input tm-textarea{(string.IsNullOrEmpty(Error) ? "" : " tm-input-error")}{(Disabled ? " tm-input-disabled" : "")}";

    private async Task HandleOnChange(ChangeEventArgs e)
    {
        if (!Immediate)
            await ValueChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);
    }

    private async Task HandleOnInput(ChangeEventArgs e)
    {
        if (Immediate)
            await ValueChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);
    }
}
