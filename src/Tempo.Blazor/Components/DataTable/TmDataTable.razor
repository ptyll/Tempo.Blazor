@namespace Tempo.Blazor.Components.DataTable
@typeparam TItem
@using Tempo.Blazor.Components.Feedback
@using Tempo.Blazor.Components.DataDisplay
@using Tempo.Blazor.Components.Inputs
@using Tempo.Blazor.Components.Filters
@using Tempo.Blazor.Interfaces
@using Tempo.Blazor.Models
@using Tempo.Blazor.Services

@* Hidden container to trigger TmDataTableColumn registration via CascadingValue. *@
<CascadingValue Value="this" IsFixed="true">
    <span style="display:none" aria-hidden="true">@ChildContent</span>
</CascadingValue>

<div class="tm-data-table-wrapper @Class" @attributes="AdditionalAttributes">

    @* ── Toolbar ─────────────────────────────────────────────── *@
    <div class="tm-data-table-toolbar">
        @* Left: Search (main action) *@
        @if (ShowSearch)
        {
            <div class="tm-data-table-toolbar-left">
                <TmSearchInput Value="@_searchText"
                               ValueChanged="OnSearchChangedAsync"
                               Placeholder="@Loc["TmDataTable_SearchPlaceholder"]" />
            </div>
        }

        @* Right: Actions (column picker, view manager) *@
        <div class="tm-data-table-toolbar-right">
            @if (ShowColumnPicker && _columns.Any(c => c.Hideable))
            {
                <TmColumnPicker Columns="@GetColumnVisibilityItems()"
                                OnToggleColumn="OnToggleColumnAsync"
                                OnReset="OnResetColumnsAsync" />
            }
            @if (ViewProvider is not null)
            {
                <TmViewManager Provider="ViewProvider"
                               ViewContext="@ViewContext"
                               OnViewApplied="ApplyViewAsync"
                               GetCurrentView="GetCurrentView"
                               GetCurrentFilters="() => _externalFilters"
                               AvailableColumns="GetAvailableColumns()"
                               FilterDefinitions="ViewFilterDefinitions"
                               CanCreateTenantViews="ViewCanCreateTenantViews"
                               CurrentUserId="CurrentUserId"
                               CurrentTenantId="CurrentTenantId" />
            }
        </div>
    </div>

    @* ── External Filter Builder (when table has views) ────── *@
    @if (ShowExternalFilterBuilder && ViewProvider is not null && ExternalFilterDefinitions?.Any() == true)
    {
        <div class="tm-data-table-external-filters" @key="_activeViewId">
            <TmFilterBuilder FilterDefinitions="ExternalFilterDefinitions"
                             ActiveFilters="_externalFilters"
                             OnFiltersChanged="OnExternalFiltersChanged"
                             ShowClearAll="true" />
        </div>
    }

    @* ── Selection bar ────────────────────────────────────────── *@
    @if (_selectedItems.Count > 0)
    {
        <div class="tm-data-table-selection-bar">
            <span>@Loc["TmDataTable_BulkActions", _selectedItems.Count]</span>
            <button class="tm-btn-link" type="button" @onclick="DeselectAllAsync">
                @Loc["TmDataTable_DeselectAll"]
            </button>
            @SelectionActions
        </div>
    }

    @* ── Grouping drop zone ────────────────────────────────────── *@
    @if (ShowGrouping)
    {
        <div class="tm-data-table-group-zone @(_isDragOver ? "tm-data-table-group-zone--dragover" : "")"
             @ondragover="HandleGroupZoneDragOver"
             @ondragover:preventDefault="true"
             @ondrop="HandleGroupZoneDrop"
             @ondragenter="() => _isDragOver = true"
             @ondragleave="() => _isDragOver = false">
            @if (_groupByColumns.Count == 0)
            {
                <span class="tm-data-table-group-placeholder">@Loc["TmDataTable_GroupDropPlaceholder"]</span>
            }
            else
            {
                @for (var i = 0; i < _groupByColumns.Count; i++)
                {
                    var index = i;
                    var colKey = _groupByColumns[i];
                    var col = _columns.FirstOrDefault(c => c.Key == colKey);
                    <div class="tm-data-table-group-chip"
                         draggable="true"
                         @ondragstart="() => OnChipDragStart(index)"
                         @ondrop="() => OnChipDrop(index)"
                         @ondragover:preventDefault="true">
                        <span>@(col?.Title ?? colKey)</span>
                        <button type="button"
                                class="tm-data-table-group-chip-remove"
                                @onclick="() => HandleRemoveGroupChip(colKey)">×</button>
                    </div>
                }
                <div class="tm-data-table-group-actions">
                    <button type="button" class="tm-data-table-group-expand-all"
                            @onclick="ExpandAllGroups">@Loc["TmDataTable_ExpandAll"]</button>
                    <button type="button" class="tm-data-table-group-collapse-all"
                            @onclick="CollapseAllGroups">@Loc["TmDataTable_CollapseAll"]</button>
                </div>
            }
        </div>
    }

    @* ── Table ────────────────────────────────────────────────── *@
    <div class="@GetScrollContainerClass()" style="@GetScrollContainerStyle()">
        <table class="tm-data-table" role="grid">
            @if (_visibleColumns.Count > 0 || Selectable)
            {
                <thead>
                    <tr>
                        @if (Selectable)
                        {
                            <th class="tm-col-check">
                                <input type="checkbox"
                                       aria-label="@Loc["TmDataTable_SelectAll"]"
                                       checked="@IsAllSelected"
                                       @onchange="ToggleSelectAllAsync" />
                            </th>
                        }
                        @foreach (var col in _visibleColumns)
                        {
                            <th class="@GetHeaderClass(col)"
                                style="@GetHeaderStyle(col)"
                                data-sortable="@col.Sortable.ToString().ToLower()"
                                draggable="@(col.Groupable ? "true" : "false")"
                                aria-sort="@GetAriaSortValue(col)"
                                @ondragstart="() => OnColumnDragStart(col.Key)"
                                @ondragend="OnColumnDragEnd"
                                @onclick="() => SortByAsync(col)">
                                @if (col.HeaderTemplate is not null)
                                {
                                    @col.HeaderTemplate
                                }
                                else
                                {
                                    <span>@col.Title</span>
                                }
                                @if (col.Sortable)
                                {
                                    <span class="tm-sort-icon @GetSortIconClass(col)" aria-hidden="true"></span>
                                }
                            </th>
                        }
                    </tr>
                    @if (_visibleColumns.Any(c => c.Filterable))
                    {
                        <tr class="tm-filter-row">
                            @if (Selectable) { <th></th> }
                            @foreach (var col in _visibleColumns)
                            {
                                <th>
                                    @if (col.Filterable)
                                    {
                                        <TmColumnFilter ColumnKey="@col.Key"
                                                        FilterType="@col.FilterType"
                                                        FilterOptions="@col.FilterOptions"
                                                        OnFilterChange="f => ApplyFilterAsync(col.Key, f)" />
                                    }
                                </th>
                            }
                        </tr>
                    }
                </thead>
            }
            <tbody>
                @if (_isLoading || IsLoading)
                {
                    <tr>
                        <td colspan="@ColSpan">
                            <TmSpinner />
                        </td>
                    </tr>
                }
                else if (_groupByColumns.Count > 0 && _groupedData is not null)
                {
                    @* ── Grouped rendering ── *@
                    @if (_groupedData.Count == 0 && !string.IsNullOrEmpty(EmptyTitle))
                    {
                        <tr>
                            <td colspan="@ColSpan">
                                <TmEmptyState Title="@EmptyTitle" />
                            </td>
                        </tr>
                    }
                    else
                    {
                        @RenderGroupRows(_groupedData, 0)
                    }
                }
                else if (!_displayedItems.Any())
                {
                    @if (!string.IsNullOrEmpty(EmptyTitle))
                    {
                        <tr>
                            <td colspan="@ColSpan">
                                <TmEmptyState Title="@EmptyTitle" />
                            </td>
                        </tr>
                    }
                }
                else if (ScrollMode == DataTableScrollMode.Virtualized)
                {
                    <Virtualize Items="@_displayedItems"
                                Context="rowItem"
                                ItemSize="VirtualItemSize"
                                OverscanCount="VirtualOverscanCount">
                        <tr class="@GetRowClass(rowItem)"
                            tabindex="0"
                            @onclick="() => HandleRowClickAsync(rowItem)"
                            @onkeydown="e => HandleRowKeyDownAsync(e, rowItem)">
                            @if (Selectable)
                            {
                                <td class="tm-col-check">
                                    <input type="checkbox"
                                           checked="@IsSelected(rowItem)"
                                           @onchange="e => ToggleRowSelectionAsync(rowItem, e)"
                                           @onclick:stopPropagation="true" />
                                </td>
                            }
                            @foreach (var col in _visibleColumns)
                            {
                                <td class="@GetCellClass(col)" style="@GetCellStyle(col)">
                                    @if (col.CellTemplate is not null)
                                    {
                                        @col.CellTemplate(rowItem)
                                    }
                                    else
                                    {
                                        @col.Field?.Invoke(rowItem)
                                    }
                                </td>
                            }
                        </tr>
                    </Virtualize>
                }
                else
                {
                    @foreach (var item in _displayedItems)
                    {
                        var rowItem = item;
                        <tr class="@GetRowClass(rowItem)"
                            tabindex="0"
                            @onclick="() => HandleRowClickAsync(rowItem)"
                            @onkeydown="e => HandleRowKeyDownAsync(e, rowItem)">
                            @if (Selectable)
                            {
                                <td class="tm-col-check">
                                    <input type="checkbox"
                                           checked="@IsSelected(rowItem)"
                                           @onchange="e => ToggleRowSelectionAsync(rowItem, e)"
                                           @onclick:stopPropagation="true" />
                                </td>
                            }
                            @foreach (var col in _visibleColumns)
                            {
                                <td class="@GetCellClass(col)" style="@GetCellStyle(col)">
                                    @if (col.CellTemplate is not null)
                                    {
                                        @col.CellTemplate(rowItem)
                                    }
                                    else
                                    {
                                        @col.Field?.Invoke(rowItem)
                                    }
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    @* ── Pagination ───────────────────────────────────────────── *@
    @if (ShowPagination && _totalPages > 1 && ScrollMode == DataTableScrollMode.Pagination)
    {
        <div class="tm-pagination-container">
            @* Left: Info *@
            <div class="tm-pagination-info">
                @Loc["TmDataTable_ShowingItems", ((_currentPage - 1) * _pageSize) + 1, Math.Min(_currentPage * _pageSize, _totalCount), _totalCount]
            </div>

            @* Center: Page controls + Page size (vše v jednom) *@
            <div class="tm-pagination-center">
                <TmPagination CurrentPage="@_currentPage"
                              TotalPages="@_totalPages"
                              TotalCount="@_totalCount"
                              PageSize="@_pageSize"
                              PageSizeOptions="PageSizeOptions"
                              OnPageChange="GoToPageAsync"
                              OnPageSizeChange="ChangePageSizeAsync" />
            </div>
        </div>
    }
</div>
