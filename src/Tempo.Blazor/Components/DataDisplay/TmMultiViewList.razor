@namespace Tempo.Blazor.Components.DataDisplay
@typeparam TItem
@using Tempo.Blazor.Interfaces
@using Tempo.Blazor.Models
@using Tempo.Blazor.Components.Filters
@using Tempo.Blazor.Components.DataTable
@using Tempo.Blazor.Components.Inputs
@using Tempo.Blazor.Services

<div class="tm-multi-view-list @Class" @attributes="AdditionalAttributes">

    @* ── Toolbar ─────────────────────────────────────────────── *@
    <div class="tm-mvl-toolbar">
        @* Left: Search *@
        @if (ShowSearch)
        {
            <div class="tm-mvl-toolbar-left">
                <TmSearchInput Value="@_searchText"
                               ValueChanged="OnSearchChangedAsync"
                               Placeholder="@Loc["TmDataTable_SearchPlaceholder"]" />
            </div>
        }

        @* Right: Group picker, View switcher, View manager *@
        <div class="tm-mvl-toolbar-right">
            @if (GroupableFields is not null && GroupableFields.Count > 0)
            {
                <div class="tm-mvl-group-picker">
                    <button type="button" class="tm-mvl-group-btn" @onclick="ToggleGroupPicker">
                        @Loc["TmMvl_GroupBy"]
                    </button>
                    @if (_groupPickerOpen)
                    {
                        <div class="tm-mvl-group-dropdown">
                            @foreach (var field in GroupableFields)
                            {
                                <label class="tm-mvl-group-option">
                                    <input type="checkbox"
                                           checked="@_activeGroupFields.Contains(field.FieldName)"
                                           @onchange="e => ToggleGroupField(field.FieldName, (bool)e.Value!)" />
                                    @field.Label
                                </label>
                            }
                        </div>
                    }
                </div>
            }
            @if (ShowViewSwitcher)
            {
                <div class="tm-mvl-switcher">
                    <button type="button"
                            class="tm-mvl-switch-table @(_viewMode == ListViewMode.Table ? "tm-mvl-switch--active" : "")"
                            aria-label="@Loc["TmMvl_TableView"]"
                            @onclick="() => SwitchView(ListViewMode.Table)">
                        <span>&#9783;</span>
                    </button>
                    <button type="button"
                            class="tm-mvl-switch-card @(_viewMode == ListViewMode.Card ? "tm-mvl-switch--active" : "")"
                            aria-label="@Loc["TmMvl_CardView"]"
                            @onclick="() => SwitchView(ListViewMode.Card)">
                        <span>&#9645;</span>
                    </button>
                    <button type="button"
                            class="tm-mvl-switch-list @(_viewMode == ListViewMode.List ? "tm-mvl-switch--active" : "")"
                            aria-label="@Loc["TmMvl_ListView"]"
                            @onclick="() => SwitchView(ListViewMode.List)">
                        <span>&#9776;</span>
                    </button>
                </div>
            }
            @if (ViewProvider is not null)
            {
                <TmViewManager Provider="ViewProvider"
                               ViewContext="@ViewContext"
                               OnViewApplied="ApplyViewAsync"
                               GetCurrentView="GetCurrentView"
                               GetCurrentFilters="() => _externalFilters"
                               AvailableColumns="GetAvailableColumns()"
                               FilterDefinitions="ViewFilterDefinitions"
                               CanCreateTenantViews="ViewCanCreateTenantViews"
                               CurrentUserId="CurrentUserId"
                               CurrentTenantId="CurrentTenantId" />
            }
        </div>
    </div>

    @* ── External Filter Builder ────────────────────────────── *@
    @if (ShowExternalFilterBuilder && ViewProvider is not null && ExternalFilterDefinitions?.Any() == true)
    {
        <div class="tm-mvl-external-filters" @key="_activeViewId">
            <TmFilterBuilder FilterDefinitions="ExternalFilterDefinitions"
                             ActiveFilters="_externalFilters"
                             OnFiltersChanged="OnExternalFiltersChanged"
                             ShowClearAll="true" />
        </div>
    }

    @* ── Content ─────────────────────────────────────────────── *@
    @if (_isLoading)
    {
        <div class="tm-mvl-loading">
            <TmSpinner Size="SpinnerSize.Md" />
        </div>
    }
    else if (!HasItems)
    {
        <TmEmptyState Title="@(!string.IsNullOrEmpty(EmptyTitle) ? EmptyTitle : Loc["Tm_NoResults"])" />
    }
    else
    {
        <div class="@GetMvlScrollContainerClass()" style="@GetMvlScrollContainerStyle()">
            @if (_viewMode == ListViewMode.Table)
            {
                <table class="tm-mvl-table">
                    <thead>
                        <tr>
                            @if (_visibleColumns.Contains(ColumnKeys.Title)) { <th>@Loc["TmMvl_ColTitle"]</th> }
                            @if (_visibleColumns.Contains(ColumnKeys.SubTitle)) { <th>@Loc["TmMvl_ColSubTitle"]</th> }
                            @if (_visibleColumns.Contains(ColumnKeys.Status)) { <th>@Loc["TmMvl_ColStatus"]</th> }
                            @if (_visibleColumns.Contains(ColumnKeys.Date)) { <th>@Loc["TmMvl_ColDate"]</th> }
                        </tr>
                    </thead>
                    <tbody>
                        @if (IsGrouped)
                        {
                            @RenderTableGroupRows(_groupedData!, 0)
                        }
                        else if (IsVirtualized)
                        {
                            <Virtualize Items="FilteredItems" Context="item" ItemSize="VirtualItemSize">
                                @RenderTableDataRow(item)
                            </Virtualize>
                        }
                        else
                        {
                            @foreach (var item in FilteredItems!)
                            {
                                @RenderTableDataRow(item)
                            }
                        }
                    </tbody>
                </table>
            }
            else if (_viewMode == ListViewMode.Card)
            {
                @if (IsGrouped)
                {
                    @RenderGroupSections(_groupedData!, 0, "card")
                }
                else if (IsVirtualized)
                {
                    <div class="tm-mvl-card-grid">
                        <Virtualize Items="FilteredItems" Context="item" ItemSize="VirtualCardHeight">
                            @RenderCardItem(item)
                        </Virtualize>
                    </div>
                }
                else
                {
                    <div class="tm-mvl-card-grid">
                        @foreach (var item in FilteredItems!)
                        {
                            @RenderCardItem(item)
                        }
                    </div>
                }
            }
            else if (_viewMode == ListViewMode.List)
            {
                @if (IsGrouped)
                {
                    @RenderGroupSections(_groupedData!, 0, "list")
                }
                else if (IsVirtualized)
                {
                    <ul class="tm-mvl-list">
                        <Virtualize Items="FilteredItems" Context="item" ItemSize="VirtualListItemHeight">
                            @RenderListItem(item)
                        </Virtualize>
                    </ul>
                }
                else
                {
                    <ul class="tm-mvl-list">
                        @foreach (var item in FilteredItems!)
                        {
                            @RenderListItem(item)
                        }
                    </ul>
                }
            }
        </div>
    }

    @* ── Pagination ───────────────────────────────────────────── *@
    @if (ShowPagination && _totalPages > 1 && ScrollMode == DataTableScrollMode.Pagination)
    {
        <div class="tm-pagination-container">
            <div class="tm-pagination-info">
                @Loc["TmDataTable_ShowingItems", ((_currentPage - 1) * _pageSize) + 1, Math.Min(_currentPage * _pageSize, _totalCount), _totalCount]
            </div>
            <div class="tm-pagination-center">
                <TmPagination CurrentPage="@_currentPage"
                              TotalPages="@_totalPages"
                              TotalCount="@_totalCount"
                              PageSize="@_pageSize"
                              OnPageChange="GoToPageAsync"
                              OnPageSizeChange="ChangePageSizeAsync" />
            </div>
        </div>
    }
</div>

@code {
    // ── Parameters: data ─────────────────────────────────────────

    /// <summary>Items to display in the list (client-side mode).</summary>
    [Parameter] public IReadOnlyList<TItem>? Items { get; set; }

    /// <summary>Server-side data provider. When set, data is loaded via this provider.</summary>
    [Parameter] public IDataTableDataProvider<TItem>? DataProvider { get; set; }

    /// <summary>When true, shows pagination bar when more than one page. Default: true.</summary>
    [Parameter] public bool ShowPagination { get; set; } = true;

    /// <summary>Default page size for pagination. Default: 25.</summary>
    [Parameter] public int DefaultPageSize { get; set; } = 25;

    // ── Parameters: mapping (quick setup) ────────────────────────

    /// <summary>Maps an item to its display title.</summary>
    [Parameter] public Func<TItem, string>? TitleField { get; set; }

    /// <summary>Maps an item to its secondary text.</summary>
    [Parameter] public Func<TItem, string?>? SubTitleField { get; set; }

    /// <summary>Maps an item to its avatar/thumbnail URL.</summary>
    [Parameter] public Func<TItem, string?>? AvatarUrlField { get; set; }

    /// <summary>Maps an item to its status label text.</summary>
    [Parameter] public Func<TItem, string?>? StatusLabelField { get; set; }

    /// <summary>Maps an item to its status badge CSS color.</summary>
    [Parameter] public Func<TItem, string?>? StatusColorField { get; set; }

    /// <summary>Maps an item to its date value.</summary>
    [Parameter] public Func<TItem, DateTimeOffset?>? DateField { get; set; }

    /// <summary>Maps an item to its unique identifier.</summary>
    [Parameter] public Func<TItem, string>? IdField { get; set; }

    // ── Parameters: template overrides ───────────────────────────

    /// <summary>Custom card template. When set, overrides default card rendering.</summary>
    [Parameter] public RenderFragment<TItem>? CardTemplate { get; set; }

    /// <summary>Custom list item template. When set, overrides default list rendering.</summary>
    [Parameter] public RenderFragment<TItem>? ListItemTemplate { get; set; }

    /// <summary>Custom table row template. When set, overrides default table row rendering.</summary>
    [Parameter] public RenderFragment<TItem>? TableRowTemplate { get; set; }

    // ── Parameters: grouping ─────────────────────────────────────

    /// <summary>Fields available for grouping in the dropdown picker.</summary>
    [Parameter] public IReadOnlyList<GroupFieldDefinition<TItem>>? GroupableFields { get; set; }

    /// <summary>Whether groups are collapsed by default.</summary>
    [Parameter] public bool GroupsCollapsedByDefault { get; set; } = true;

    /// <summary>Fires when grouping configuration changes.</summary>
    [Parameter] public EventCallback<IReadOnlyList<string>> OnGroupingChanged { get; set; }

    // ── Parameters: virtualization ────────────────────────────────

    /// <summary>Scroll mode: Pagination (default) or Virtualized.</summary>
    [Parameter] public DataTableScrollMode ScrollMode { get; set; } = DataTableScrollMode.Pagination;

    /// <summary>Height of the virtual scroll container. Default: "600px".</summary>
    [Parameter] public string? VirtualScrollHeight { get; set; }

    /// <summary>Estimated item height for table row virtualization.</summary>
    [Parameter] public float VirtualItemSize { get; set; } = 48f;

    /// <summary>Estimated card height for card view virtualization.</summary>
    [Parameter] public float VirtualCardHeight { get; set; } = 180f;

    /// <summary>Estimated list item height for list view virtualization.</summary>
    [Parameter] public float VirtualListItemHeight { get; set; } = 56f;

    // ── Parameters: display ──────────────────────────────────────

    /// <summary>Current display mode (Table/Card/List). Two-way bindable.</summary>
    [Parameter] public ListViewMode ViewMode { get; set; } = ListViewMode.Table;

    /// <summary>Fires when the user switches the view mode.</summary>
    [Parameter] public EventCallback<ListViewMode> ViewModeChanged { get; set; }

    /// <summary>Fires when an item row/card is clicked.</summary>
    [Parameter] public EventCallback<TItem> OnItemClick { get; set; }

    /// <summary>When true, shows the view-mode switcher buttons above the list.</summary>
    [Parameter] public bool ShowViewSwitcher { get; set; } = true;

    /// <summary>When true, shows the global search input.</summary>
    [Parameter] public bool ShowSearch { get; set; } = true;

    /// <summary>Title for the empty state when Items is empty.</summary>
    [Parameter] public string? EmptyTitle { get; set; }

    /// <summary>Additional CSS class for the root element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Additional HTML attributes to apply to the root element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    // ── View Manager Parameters ───────────────────────────────────

    /// <summary>
    /// Unique identifier for this list instance.
    /// Used to scope saved views to specific lists (e.g., "team-members", "projects").
    /// </summary>
    [Parameter, EditorRequired] public string ViewContext { get; set; } = default!;

    /// <summary>Optional view persistence provider. When set, shows TmViewManager.</summary>
    [Parameter] public IDataTableViewProvider? ViewProvider { get; set; }

    /// <summary>Filter definitions for the view manager filter builder.</summary>
    [Parameter] public List<FilterDefinition> ViewFilterDefinitions { get; set; } = [];

    /// <summary>When true, shows FilterBuilder for external filtering.</summary>
    [Parameter] public bool ShowExternalFilterBuilder { get; set; } = true;

    /// <summary>Filter definitions for the external filter builder.</summary>
    [Parameter] public List<FilterDefinition> ExternalFilterDefinitions { get; set; } = [];

    /// <summary>Whether the user can create tenant-wide views.</summary>
    [Parameter] public bool ViewCanCreateTenantViews { get; set; }

    /// <summary>Current user ID for personal view scoping.</summary>
    [Parameter] public string? CurrentUserId { get; set; }

    /// <summary>Current tenant ID for tenant view scoping.</summary>
    [Parameter] public string? CurrentTenantId { get; set; }

    // ── Column key constants ─────────────────────────────────────
    private static class ColumnKeys
    {
        public const string Title = "Title";
        public const string SubTitle = "SubTitle";
        public const string Status = "Status";
        public const string Date = "Date";
        public const string Avatar = "Avatar";
    }

    // ── State ─────────────────────────────────────────────────────
    private ListViewMode _viewMode = ListViewMode.Table;
    private string _searchText = string.Empty;
    private List<ActiveFilter> _externalFilters = [];
    private string? _activeViewId;
    private HashSet<string> _visibleColumns = [ColumnKeys.Title, ColumnKeys.SubTitle, ColumnKeys.Status, ColumnKeys.Date];

    // ── Server-side state ─────────────────────────────────────────
    private List<TItem> _serverItems = [];
    private bool _isLoading;
    private int _currentPage = 1;
    private int _pageSize = 25;
    private int _totalCount;
    private int _totalPages;

    // ── Grouping state ───────────────────────────────────────────
    private readonly List<string> _activeGroupFields = [];
    private readonly HashSet<string> _expandedGroups = new();
    private IReadOnlyList<DataGroup<TItem>>? _groupedData;
    private bool _groupPickerOpen;
    private bool IsGrouped => _activeGroupFields.Count > 0 && _groupedData is not null;
    private bool IsVirtualized => ScrollMode == DataTableScrollMode.Virtualized;

    private bool HasItems => (IsGrouped ? _groupedData?.Count > 0 : FilteredItems?.Count > 0) == true;

    private List<TItem>? FilteredItems
    {
        get
        {
            // Server-side: use loaded items directly
            if (DataProvider is not null)
                return _serverItems.Count > 0 ? _serverItems : null;

            if (Items == null) return null;

            var query = Items.AsEnumerable();

            // Apply search
            if (!string.IsNullOrWhiteSpace(_searchText))
            {
                var term = _searchText.Trim();
                query = query.Where(item =>
                    (GetTitle(item)?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (GetSubTitle(item)?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (GetStatusLabel(item)?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            // Apply filters
            foreach (var filter in _externalFilters)
            {
                query = ApplyFilter(query, filter);
            }

            return query.ToList();
        }
    }

    // ── Field accessors (Hybrid: mapping > IMultiViewListItem > null) ──

    private string? GetTitle(TItem item) =>
        TitleField is not null ? TitleField(item) :
        item is IMultiViewListItem mvl ? mvl.Title : null;

    private string? GetSubTitle(TItem item) =>
        SubTitleField is not null ? SubTitleField(item) :
        item is IMultiViewListItem mvl ? mvl.SubTitle : null;

    private string? GetAvatarUrl(TItem item) =>
        AvatarUrlField is not null ? AvatarUrlField(item) :
        item is IMultiViewListItem mvl ? mvl.AvatarUrl : null;

    private string? GetStatusLabel(TItem item) =>
        StatusLabelField is not null ? StatusLabelField(item) :
        item is IMultiViewListItem mvl ? mvl.StatusLabel : null;

    private string? GetStatusColor(TItem item) =>
        StatusColorField is not null ? StatusColorField(item) :
        item is IMultiViewListItem mvl ? mvl.StatusColor : null;

    private DateTimeOffset? GetDate(TItem item) =>
        DateField is not null ? DateField(item) :
        item is IMultiViewListItem mvl ? mvl.Date : null;

    // ── Filter logic ─────────────────────────────────────────────

    private IEnumerable<TItem> ApplyFilter(IEnumerable<TItem> query, ActiveFilter filter)
    {
        var value = filter.DisplayValue?.ToLowerInvariant() ?? "";
        return filter.FieldName.ToLowerInvariant() switch
        {
            "title" => query.Where(i => GetTitle(i)?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false),
            "subtitle" => query.Where(i => GetSubTitle(i)?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false),
            "status" => query.Where(i => GetStatusLabel(i)?.Equals(value, StringComparison.OrdinalIgnoreCase) ?? false),
            _ => query
        };
    }

    // ── Lifecycle ─────────────────────────────────────────────────

    private bool _dataLoaded;

    protected override async Task OnInitializedAsync()
    {
        if (_dataLoaded) return;

        _pageSize = DefaultPageSize;

        if (DataProvider is not null)
            await LoadFromProviderAsync();

        _dataLoaded = true;
    }

    protected override void OnParametersSet()
    {
        _viewMode = ViewMode;
    }

    // ── Server-side data loading ─────────────────────────────────

    private async Task LoadFromProviderAsync()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var query = new DataTableQuery
            {
                Page = _currentPage,
                PageSize = _pageSize,
                SearchText = _searchText,
            };
            var result = await DataProvider!.GetDataAsync(query);
            _serverItems = result.Items.ToList();
            _totalCount = result.TotalCount;
            _currentPage = result.Page;
            _pageSize = result.PageSize;
            _totalPages = result.TotalPages;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task GoToPageAsync(int page)
    {
        _currentPage = page;
        if (DataProvider is not null)
            await LoadFromProviderAsync();
    }

    private async Task ChangePageSizeAsync(int size)
    {
        _pageSize = size;
        _currentPage = 1;
        if (DataProvider is not null)
            await LoadFromProviderAsync();
    }

    private async Task SwitchView(ListViewMode mode)
    {
        _viewMode = mode;
        await ViewModeChanged.InvokeAsync(mode);
    }

    private async Task OnSearchChangedAsync(string? value)
    {
        _searchText = value ?? string.Empty;
        if (DataProvider is not null)
        {
            _currentPage = 1;
            await LoadFromProviderAsync();
        }
    }

    private async Task OnExternalFiltersChanged(IEnumerable<ActiveFilter> filters)
    {
        _externalFilters = filters.ToList();
        if (DataProvider is not null)
        {
            _currentPage = 1;
            await LoadFromProviderAsync();
        }
    }

    private Task ApplyViewAsync(DataTableView view)
    {
        _activeViewId = view.Id;

        // Update visible columns
        if (view.VisibleColumns?.Count > 0)
        {
            _visibleColumns = new HashSet<string>(view.VisibleColumns);
        }

        // Update filters
        _externalFilters = view.Filters?.Where(f => !string.IsNullOrEmpty(f.Value)).Select(f => new ActiveFilter(
            f.FieldName,
            f.FieldName,
            ParseFilterOperator(f.Operator),
            f.Value,
            f.Value
        )).ToList() ?? [];

        // Apply grouping
        _activeGroupFields.Clear();
        if (view.GroupByColumns?.Count > 0)
        {
            _activeGroupFields.AddRange(view.GroupByColumns);
            _expandedGroups.Clear();
            RefreshGroupedData();
        }
        else
        {
            _groupedData = null;
        }

        return Task.CompletedTask;
    }

    private DataTableView GetCurrentView() => new()
    {
        Name = Loc["TmMvl_CurrentViewName"],
        VisibleColumns = _visibleColumns.ToList(),
        Filters = _externalFilters.Select(f => new FilterConfig
        {
            FieldName = f.FieldName,
            Operator = f.Operator.ToString(),
            Value = f.Value?.ToString() ?? ""
        }).ToList()
    };

    private List<ViewColumnInfo> GetAvailableColumns() =>
    [
        new ViewColumnInfo { Key = ColumnKeys.Title, Title = Loc["TmMvl_ColTitle"], Visible = _visibleColumns.Contains(ColumnKeys.Title) },
        new ViewColumnInfo { Key = ColumnKeys.SubTitle, Title = Loc["TmMvl_ColSubTitle"], Visible = _visibleColumns.Contains(ColumnKeys.SubTitle) },
        new ViewColumnInfo { Key = ColumnKeys.Status, Title = Loc["TmMvl_ColStatus"], Visible = _visibleColumns.Contains(ColumnKeys.Status) },
        new ViewColumnInfo { Key = ColumnKeys.Date, Title = Loc["TmMvl_ColDate"], Visible = _visibleColumns.Contains(ColumnKeys.Date) },
        new ViewColumnInfo { Key = ColumnKeys.Avatar, Title = Loc["TmMvl_ColAvatar"], Visible = _visibleColumns.Contains(ColumnKeys.Avatar) }
    ];

    private static FilterOperator ParseFilterOperator(string? op) => Helpers.FilterOperatorParser.Parse(op);

    // ── Grouping ─────────────────────────────────────────────────

    private void ToggleGroupPicker()
    {
        _groupPickerOpen = !_groupPickerOpen;
    }

    private void ToggleGroupField(string fieldName, bool enabled)
    {
        if (enabled && !_activeGroupFields.Contains(fieldName))
        {
            _activeGroupFields.Add(fieldName);
        }
        else if (!enabled)
        {
            _activeGroupFields.Remove(fieldName);
        }

        _groupPickerOpen = false;
        _expandedGroups.Clear();
        RefreshGroupedData();
        _ = OnGroupingChanged.InvokeAsync(_activeGroupFields.ToList());
    }

    private void RefreshGroupedData()
    {
        if (_activeGroupFields.Count == 0 || GroupableFields is null)
        {
            _groupedData = null;
            return;
        }

        var items = FilteredItems ?? [];

        var levels = _activeGroupFields.Select(fieldName =>
        {
            var def = GroupableFields.FirstOrDefault(f => f.FieldName == fieldName);
            return def is not null
                ? new GroupingLevel<TItem>(
                    fieldName,
                    def.FieldAccessor,
                    def.DisplayFormatter)
                : null;
        }).Where(l => l is not null).Cast<GroupingLevel<TItem>>().ToList();

        _groupedData = DataGroupingService.GroupItems(items, levels);
    }

    private void ToggleGroupExpansion(string groupKey)
    {
        if (!_expandedGroups.Remove(groupKey))
            _expandedGroups.Add(groupKey);
    }

    private bool IsGroupExpanded(DataGroup<TItem> group)
    {
        var key = $"{group.FieldName}:{group.Key}";
        return GroupsCollapsedByDefault ? _expandedGroups.Contains(key) : !_expandedGroups.Contains(key);
    }

    private string GetGroupKey(DataGroup<TItem> group) => $"{group.FieldName}:{group.Key}";

    private int MvlColSpan => _visibleColumns.Count;

    private string GetMvlScrollContainerClass() =>
        IsVirtualized ? "tm-mvl-virtual-scroll" : "";

    private string GetMvlScrollContainerStyle() =>
        IsVirtualized ? $"height: {VirtualScrollHeight ?? "600px"}; overflow-y: auto;" : "";

    // ── Render fragments ──────────────────────────────────────────

    private RenderFragment RenderTableGroupRows(IReadOnlyList<DataGroup<TItem>> groups, int level) => __builder =>
    {
        foreach (var group in groups)
        {
            var groupKey = GetGroupKey(group);
            var expanded = IsGroupExpanded(group);

            <tr class="tm-mvl-group-row tm-mvl-group-level-@level">
                <td colspan="@MvlColSpan">
                    <button type="button" class="tm-mvl-group-toggle" @onclick="() => ToggleGroupExpansion(groupKey)">
                        @(expanded ? "▼" : "►")
                    </button>
                    <span class="tm-mvl-group-label">@(group.DisplayValue ?? group.Key)</span>
                    <span class="tm-mvl-group-count">(@group.Count)</span>
                </td>
            </tr>

            if (expanded)
            {
                if (group.SubGroups is { Count: > 0 })
                {
                    @RenderTableGroupRows(group.SubGroups, level + 1)
                }
                else
                {
                    foreach (var item in group.Items)
                    {
                        @RenderTableDataRow(item)
                    }
                }
            }
        }
    };

    private Task HandleItemKeyDownAsync(KeyboardEventArgs e, TItem item)
    {
        if (e.Key is "Enter" or " ")
            return OnItemClick.InvokeAsync(item);
        return Task.CompletedTask;
    }

    private RenderFragment RenderTableDataRow(TItem item) => __builder =>
    {
        <tr class="tm-mvl-row" tabindex="0" @onclick="() => OnItemClick.InvokeAsync(item)" @onkeydown="e => HandleItemKeyDownAsync(e, item)">
            @if (TableRowTemplate is not null)
            {
                @TableRowTemplate(item)
            }
            else
            {
                if (_visibleColumns.Contains(ColumnKeys.Title)) { <td>@GetTitle(item)</td> }
                if (_visibleColumns.Contains(ColumnKeys.SubTitle)) { <td>@GetSubTitle(item)</td> }
                if (_visibleColumns.Contains(ColumnKeys.Status))
                {
                    <td>
                        @if (!string.IsNullOrEmpty(GetStatusLabel(item)))
                        {
                            <span class="tm-mvl-status" style="@(GetStatusColor(item) is { } c ? $"background:{c}" : "")">
                                @GetStatusLabel(item)
                            </span>
                        }
                    </td>
                }
                if (_visibleColumns.Contains(ColumnKeys.Date)) { <td>@GetDate(item)?.ToString("d")</td> }
            }
        </tr>
    };

    private RenderFragment RenderGroupSections(IReadOnlyList<DataGroup<TItem>> groups, int level, string viewType) => __builder =>
    {
        foreach (var group in groups)
        {
            var groupKey = GetGroupKey(group);
            var expanded = IsGroupExpanded(group);

            <div class="tm-mvl-group-section tm-mvl-group-level-@level">
                <div class="tm-mvl-group-header">
                    <button type="button" class="tm-mvl-group-toggle" @onclick="() => ToggleGroupExpansion(groupKey)">
                        @(expanded ? "▼" : "►")
                    </button>
                    <span class="tm-mvl-group-label">@(group.DisplayValue ?? group.Key)</span>
                    <span class="tm-mvl-group-count">(@group.Count)</span>
                </div>

                @if (expanded)
                {
                    if (group.SubGroups is { Count: > 0 })
                    {
                        @RenderGroupSections(group.SubGroups, level + 1, viewType)
                    }
                    else if (viewType == "card")
                    {
                        <div class="tm-mvl-card-grid">
                            @foreach (var item in group.Items)
                            {
                                @RenderCardItem(item)
                            }
                        </div>
                    }
                    else
                    {
                        <ul class="tm-mvl-list">
                            @foreach (var item in group.Items)
                            {
                                @RenderListItem(item)
                            }
                        </ul>
                    }
                }
            </div>
        }
    };

    private RenderFragment RenderCardItem(TItem item) => __builder =>
    {
        <div class="tm-mvl-card" role="button" tabindex="0" @onclick="() => OnItemClick.InvokeAsync(item)" @onkeydown="e => HandleItemKeyDownAsync(e, item)">
            @if (CardTemplate is not null)
            {
                @CardTemplate(item)
            }
            else
            {
                @if (!string.IsNullOrEmpty(GetAvatarUrl(item)))
                {
                    <img class="tm-mvl-card-avatar" src="@GetAvatarUrl(item)" alt="" />
                }
                <div class="tm-mvl-card-body">
                    <div class="tm-mvl-card-title">@GetTitle(item)</div>
                    @if (!string.IsNullOrEmpty(GetSubTitle(item)))
                    {
                        <div class="tm-mvl-card-subtitle">@GetSubTitle(item)</div>
                    }
                    @if (!string.IsNullOrEmpty(GetStatusLabel(item)))
                    {
                        <span class="tm-mvl-status" style="@(GetStatusColor(item) is { } c ? $"background:{c}" : "")">
                            @GetStatusLabel(item)
                        </span>
                    }
                </div>
            }
        </div>
    };

    private RenderFragment RenderListItem(TItem item) => __builder =>
    {
        <li class="tm-mvl-list-item" tabindex="0" @onclick="() => OnItemClick.InvokeAsync(item)" @onkeydown="e => HandleItemKeyDownAsync(e, item)">
            @if (ListItemTemplate is not null)
            {
                @ListItemTemplate(item)
            }
            else
            {
                @if (!string.IsNullOrEmpty(GetAvatarUrl(item)))
                {
                    <img class="tm-mvl-list-avatar" src="@GetAvatarUrl(item)" alt="" />
                }
                <div class="tm-mvl-list-content">
                    <span class="tm-mvl-list-title">@GetTitle(item)</span>
                    @if (!string.IsNullOrEmpty(GetSubTitle(item)))
                    {
                        <span class="tm-mvl-list-subtitle">@GetSubTitle(item)</span>
                    }
                </div>
                @if (!string.IsNullOrEmpty(GetStatusLabel(item)))
                {
                    <span class="tm-mvl-status" style="@(GetStatusColor(item) is { } c ? $"background:{c}" : "")">
                        @GetStatusLabel(item)
                    </span>
                }
            }
        </li>
    };
}
