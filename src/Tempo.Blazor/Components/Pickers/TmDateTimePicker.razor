@namespace Tempo.Blazor.Components.Pickers

<div class="tm-datetime-picker @Class @(IsOutOfRange ? "tm-datetime-picker--invalid" : "")" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="tm-picker-label">@Label</label>
    }

    <div class="tm-datetime-picker-body">
        <!-- Date section -->
        <div class="tm-datetime-date-section">
            <div class="tm-date-picker-input-row">
                <button type="button"
                        class="tm-date-picker-trigger"
                        disabled="@Disabled"
                        aria-haspopup="true"
                        aria-expanded="@_isOpen"
                        @onclick="ToggleCalendar">
                    @if (_date.HasValue)
                    {
                        @_date.Value.ToString(DateFormat)
                    }
                    else
                    {
                        <span class="tm-picker-placeholder">@(Placeholder ?? Loc["TmDateTimePicker_Placeholder"])</span>
                    }
                    <span class="tm-date-picker-icon" aria-hidden="true"></span>
                </button>

                @if (Value.HasValue && !Disabled && !HideClear)
                {
                    <button type="button"
                            class="tm-picker-clear"
                            aria-label="@Loc["TmDateTimePicker_Clear"]"
                            @onclick="ClearValue">
                        &#x2715;
                    </button>
                }
            </div>

            @if (_isOpen)
            {
                <div class="tm-date-picker-popup" role="dialog" aria-modal="true">
                    <TmCalendarGrid DisplayYear="@_displayYear"
                                    DisplayMonth="@_displayMonth"
                                    SelectedDate="@_date"
                                    MinDate="@(_minDate)"
                                    MaxDate="@(_maxDate)"
                                    OnDateSelected="OnDateSelected"
                                    OnNavigate="OnNavigate" />
                </div>
            }
        </div>

        <!-- Time section -->
        <div class="tm-datetime-time-section">
            <TmTimeInput Value="@_time"
                         ValueChanged="OnTimeChanged"
                         ShowSeconds="@ShowSeconds"
                         Disabled="@Disabled"
                         MinTime="@_minTime"
                         MaxTime="@_maxTime" />
        </div>
    </div>
</div>

@code {
    [Parameter] public DateTime?  Value        { get; set; }
    [Parameter] public EventCallback<DateTime?> ValueChanged { get; set; }
    [Parameter] public DateTime?  MinValue     { get; set; }
    [Parameter] public DateTime?  MaxValue     { get; set; }
    [Parameter] public string     DateFormat   { get; set; } = "dd.MM.yyyy";
    [Parameter] public bool       ShowSeconds  { get; set; }
    [Parameter] public string?    Placeholder  { get; set; }
    [Parameter] public bool       Disabled     { get; set; }
    [Parameter] public bool       Required     { get; set; }
    [Parameter] public bool       HideClear    { get; set; }
    [Parameter] public string?    Label        { get; set; }
    [Parameter] public string?    Class        { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool      _isOpen;
    private int       _displayYear  = DateTime.Today.Year;
    private int       _displayMonth = DateTime.Today.Month;
    private DateOnly? _date;
    private TimeOnly? _time;

    // Derived min/max for the time component
    private TimeOnly? _minTime;
    private TimeOnly? _maxTime;
    private DateOnly? _minDate;
    private DateOnly? _maxDate;

    private bool IsOutOfRange =>
        Value.HasValue &&
        ((MinValue.HasValue && Value.Value < MinValue.Value) ||
         (MaxValue.HasValue && Value.Value > MaxValue.Value));

    protected override void OnParametersSet()
    {
        if (Value.HasValue)
        {
            _date = DateOnly.FromDateTime(Value.Value);
            _time = TimeOnly.FromDateTime(Value.Value);
            _displayYear  = _date.Value.Year;
            _displayMonth = _date.Value.Month;
        }
        else
        {
            _date = null;
            _time = null;
        }

        _minDate = MinValue.HasValue ? DateOnly.FromDateTime(MinValue.Value) : null;
        _maxDate = MaxValue.HasValue ? DateOnly.FromDateTime(MaxValue.Value) : null;

        // Min/max time is only relevant when the selected date equals the limit date
        _minTime = (MinValue.HasValue && _date == _minDate)
            ? TimeOnly.FromDateTime(MinValue.Value) : null;
        _maxTime = (MaxValue.HasValue && _date == _maxDate)
            ? TimeOnly.FromDateTime(MaxValue.Value) : null;
    }

    private void ToggleCalendar()
    {
        if (!Disabled) _isOpen = !_isOpen;
    }

    private async Task OnDateSelected(DateOnly d)
    {
        _isOpen = false;
        _date   = d;
        await Emit();
    }

    private void OnNavigate((int Year, int Month) nav)
    {
        _displayYear  = nav.Year;
        _displayMonth = nav.Month;
    }

    private async Task OnTimeChanged(TimeOnly? t)
    {
        _time = t;
        await Emit();
    }

    private async Task ClearValue()
    {
        _date   = null;
        _time   = null;
        _isOpen = false;
        await ValueChanged.InvokeAsync(null);
    }

    private async Task Emit()
    {
        if (_date.HasValue)
        {
            var t   = _time ?? TimeOnly.MinValue;
            var dt  = _date.Value.ToDateTime(t);
            await ValueChanged.InvokeAsync(dt);
        }
    }
}
