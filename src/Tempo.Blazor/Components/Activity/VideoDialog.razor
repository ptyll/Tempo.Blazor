@namespace Tempo.Blazor.Components.Activity

@if (IsVisible)
{
    <div class="tm-rte-video-dialog">
        <div class="tm-rte-video-backdrop" @onclick="OnBackdropClick"></div>
        <div class="tm-rte-video-content">
            <div class="tm-rte-video-header">
                <h5>@Loc["TmRichEditor_VideoDialog_Title"]</h5>
                <button type="button" class="tm-rte-btn-close" @onclick="OnCancelClick">&times;</button>
            </div>
            <div class="tm-rte-video-body">
                <div class="tm-rte-form-group">
                    <label for="video-url-input">@Loc["TmRichEditor_VideoDialog_Url"]</label>
                    <input type="text"
                           id="video-url-input"
                           class="tm-rte-video-url-input"
                           placeholder="https://youtube.com/watch?v=..."
                           @bind="_url"
                           @bind:event="oninput" />
                    <small class="tm-rte-help-text">@Loc["TmRichEditor_VideoDialog_Help"]</small>
                </div>
                <div class="tm-rte-form-group">
                    <label for="video-title-input">@Loc["TmRichEditor_VideoDialog_TitleLabel"]</label>
                    <input type="text"
                           id="video-title-input"
                           class="tm-rte-video-title-input"
                           placeholder="@Loc["TmRichEditor_VideoDialog_TitlePlaceholder"]"
                           @bind="_title"
                           @bind:event="oninput" />
                </div>
            </div>
            <div class="tm-rte-video-footer">
                <button type="button" class="tm-btn tm-btn-secondary tm-btn-sm tm-rte-btn-cancel" @onclick="OnCancelClick">
                    @Loc["Tm_Cancel"]
                </button>
                <button type="button" 
                        class="tm-btn tm-btn-primary tm-btn-sm tm-rte-btn-insert"
                        disabled="@(!IsValidUrl())"
                        @onclick="InsertVideo">
                    @Loc["TmRichEditor_VideoDialog_Insert"]
                </button>
            </div>
        </div>
    </div>
}

@code {
    /// <summary>
    /// Whether the dialog is visible.
    /// </summary>
    [Parameter] public bool IsVisible { get; set; }
    
    /// <summary>
    /// Whether to close on backdrop click.
    /// </summary>
    [Parameter] public bool CloseOnBackdropClick { get; set; } = true;
    
    /// <summary>
    /// Callback when video is confirmed.
    /// </summary>
    [Parameter] public EventCallback<(string Url, string Title)> OnConfirm { get; set; }
    
    /// <summary>
    /// Callback when dialog is cancelled.
    /// </summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    private string _url = string.Empty;
    private string _title = string.Empty;

    private bool IsValidUrl()
    {
        if (string.IsNullOrWhiteSpace(_url))
            return false;

        // Accept YouTube, Vimeo, or direct URLs
        return _url.Contains("youtube.com") || 
               _url.Contains("youtu.be") || 
               _url.Contains("vimeo.com") ||
               Uri.TryCreate(_url, UriKind.Absolute, out var uri) && 
               (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);
    }

    private async Task InsertVideo()
    {
        if (!IsValidUrl()) return;

        await OnConfirm.InvokeAsync((_url, string.IsNullOrWhiteSpace(_title) ? "Video" : _title));
        Reset();
    }

    private async Task OnBackdropClick()
    {
        if (CloseOnBackdropClick)
        {
            await OnCancel.InvokeAsync();
        }
    }

    private async Task OnCancelClick()
    {
        await OnCancel.InvokeAsync();
    }

    private void Reset()
    {
        _url = string.Empty;
        _title = string.Empty;
    }
}
