@namespace Tempo.Blazor.Components.Dropdowns
@using Tempo.Blazor.Components.Icons
@using Microsoft.AspNetCore.Components.Web

<div class="tm-dropdown-wrapper @(Disabled ? "tm-dropdown-disabled" : "") @Class" @onkeydown="HandleKeyDownAsync" @attributes="AdditionalAttributes">
    <button type="button"
            class="tm-dropdown-trigger"
            aria-expanded="@_isOpen.ToString().ToLowerInvariant()"
            aria-haspopup="true"
            @onclick="Toggle">
        @if (!string.IsNullOrEmpty(Icon))
        {
            <TmIcon Name="@Icon" Size="IconSize.Sm" />
        }
        <span>@Text</span>
        <TmIcon Name="@((_isOpen ? IconNames.ChevronUp : IconNames.ChevronDown))" Size="IconSize.Sm" />
    </button>

    @if (_isOpen)
    {
        <div class="tm-dropdown-menu" role="menu">
            <CascadingValue Value="this">
                @ChildContent
            </CascadingValue>
        </div>
    }
</div>

@code {
    /// <summary>Trigger button label.</summary>
    [Parameter] public string Text { get; set; } = string.Empty;

    /// <summary>Optional leading icon on the trigger button.</summary>
    [Parameter] public string? Icon { get; set; }

    /// <summary>Fires when a dropdown item is selected (value = item key).</summary>
    [Parameter] public EventCallback<string> OnSelect { get; set; }

    /// <summary>Menu content — typically TmDropdownItem elements.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Additional CSS class for the root element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Disables the dropdown.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Additional HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _isOpen;

    private void Toggle()
    {
        if (Disabled) return;
        _isOpen = !_isOpen;
    }

    /// <summary>Called by TmDropdownItem when an item is selected.</summary>
    public async Task SelectItemAsync(string value)
    {
        if (Disabled) return;
        await OnSelect.InvokeAsync(value);
        _isOpen = false;
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            _isOpen = false;
            await Task.CompletedTask;
        }
    }
}
