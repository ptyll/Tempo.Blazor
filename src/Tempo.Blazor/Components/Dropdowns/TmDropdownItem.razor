@namespace Tempo.Blazor.Components.Dropdowns
@using Tempo.Blazor.Components.Icons

<button type="button"
        class="tm-dropdown-item @(Disabled ? "tm-dropdown-item-disabled" : "") @Class"
        role="menuitem"
        disabled="@Disabled"
        @onclick="HandleClickAsync"
        @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <TmIcon Name="@Icon" Size="IconSize.Sm" />
    }
    @ChildContent
</button>

@code {
    /// <summary>Value passed to TmDropdown.OnSelect when clicked.</summary>
    [Parameter] public string Value { get; set; } = string.Empty;

    /// <summary>Optional leading icon.</summary>
    [Parameter] public string? Icon { get; set; }

    /// <summary>Item content.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Additional CSS class for the item.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Disables the dropdown item.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Additional HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    [CascadingParameter] private TmDropdown? Parent { get; set; }

    private async Task HandleClickAsync()
    {
        if (Disabled) return;
        if (Parent is not null)
            await Parent.SelectItemAsync(Value);
    }
}
