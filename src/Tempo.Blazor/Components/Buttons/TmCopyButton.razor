@namespace Tempo.Blazor.Components.Buttons
@using Microsoft.JSInterop
@inject IJSRuntime JS

<button type="button"
        class="tm-copy-button @(_copied ? "tm-copy-button--copied" : "") @Class"
        disabled="@Disabled"
        aria-label="@(_copied ? "Copied" : "Copy to clipboard")"
        @onclick="HandleCopy"
        @attributes="AdditionalAttributes">
    @if (_copied)
    {
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12" />
        </svg>
    }
    else
    {
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
        </svg>
    }
</button>

@code {
    private bool _copied;

    /// <summary>Text to copy to clipboard.</summary>
    [Parameter, EditorRequired] public string Text { get; set; } = default!;

    /// <summary>Additional CSS class.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Disables the button.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Additional HTML attributes to apply to the button element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private async Task HandleCopy()
    {
        if (Disabled) return;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", Text);
            _copied = true;
            StateHasChanged();

            await Task.Delay(2000);
            _copied = false;
            StateHasChanged();
        }
        catch (JSException) { }
        catch (JSDisconnectedException) { }
        catch (InvalidOperationException) { }
        catch (TaskCanceledException) { }
    }
}
