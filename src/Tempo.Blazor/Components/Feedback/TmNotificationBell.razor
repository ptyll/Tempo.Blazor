@namespace Tempo.Blazor.Components.Feedback
@using Tempo.Blazor.Interfaces
@using Tempo.Blazor.Components.Icons

<div class="tm-notification-bell">
    <button type="button"
            class="tm-notification-bell-button"
            aria-label="@Loc["TmNotificationBell_AriaLabel"]"
            @onclick="Toggle">
        <TmIcon Name="@IconNames.Bell" Size="IconSize.Sm" />
        @if (UnreadCount > 0)
        {
            <span class="tm-notification-badge">@UnreadCount</span>
        }
    </button>

    @if (_isOpen)
    {
        <div class="tm-notification-dropdown">
            <div class="tm-notification-header">
                <span class="tm-notification-title">@Loc["TmNotificationBell_AriaLabel"]</span>
                @if (UnreadCount > 0)
                {
                    <button type="button"
                            class="tm-notification-mark-all-read"
                            @onclick="async () => await OnMarkAllRead.InvokeAsync()">
                        @Loc["TmNotificationBell_MarkAllRead"]
                    </button>
                }
            </div>

            <div class="tm-notification-list">
                @if (Items?.Count > 0)
                {
                    @foreach (var item in Items)
                    {
                        <div class="tm-notification-item @(item.IsRead ? "" : "tm-notification-unread")"
                             @onclick="async () => await OnItemClick.InvokeAsync(item.Id)">
                            <div class="tm-notification-item-content">
                                <span class="tm-notification-item-title">@item.Title</span>
                                @if (!string.IsNullOrEmpty(item.Body))
                                {
                                    <span class="tm-notification-item-message">@item.Body</span>
                                }
                                <span class="tm-notification-item-time">@FormatTime(item.CreatedAt)</span>
                            </div>
                            @if (!item.IsRead)
                            {
                                <span class="tm-notification-unread-dot" aria-hidden="true"></span>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="tm-notification-empty">@Loc["TmNotificationBell_NoNotifications"]</div>
                }
            </div>
        </div>
    }
</div>

@code {
    /// <summary>Notification items to display.</summary>
    [Parameter] public IReadOnlyList<INotificationItem>? Items { get; set; }

    /// <summary>Fires when the "Mark all as read" button is clicked.</summary>
    [Parameter] public EventCallback OnMarkAllRead { get; set; }

    /// <summary>Fires when a notification item is clicked. Argument = item Id.</summary>
    [Parameter] public EventCallback<string> OnItemClick { get; set; }

    private bool _isOpen;

    private int UnreadCount => Items?.Count(n => !n.IsRead) ?? 0;

    private void Toggle() => _isOpen = !_isOpen;

    private string FormatTime(DateTimeOffset ts)
    {
        var diff = DateTimeOffset.Now - ts;
        if (diff.TotalMinutes < 1) return Loc["TmTimeline_JustNow"];
        if (diff.TotalHours   < 1) return Loc["TmTimeline_MinutesAgo", (int)diff.TotalMinutes];
        if (diff.TotalDays    < 1) return Loc["TmTimeline_HoursAgo",   (int)diff.TotalHours];
        return Loc["TmTimeline_DaysAgo", (int)diff.TotalDays];
    }
}
