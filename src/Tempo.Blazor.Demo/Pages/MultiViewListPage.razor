    private void OnItemClick(IMultiViewListItem item)
    {
        Console.WriteLine($"Clicked: {item.Title}");
    }

    // Implementation classes
    private class TeamMember : IMultiViewListItem
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Title { get; set; } = "";
        public string? SubTitle { get; set; }
        public string? StatusLabel { get; set; }
        public string? StatusColor { get; set; }
        public DateTimeOffset? Date { get; set; }
        public string? AvatarUrl { get; set; }
        public IReadOnlyList<ITag> Tags { get; set; } = Array.Empty<ITag>();
    }

    private class Project : IMultiViewListItem
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
