    private string CurrentUserId => "CurrentUserId";
    private string CurrentTenantId => "CurrentTenantId";

    // Filter definitions for View Manager
    private List<FilterDefinition> _filterDefs = 
    [
        new FilterDefinition 
        { 
            FieldName = "Title", 
            FieldLabel = "Name", 
            FieldType = FilterFieldType.Text 
        },
        new FilterDefinition 
        { 
            FieldName = "Status", 
            FieldLabel = "Status", 
            FieldType = FilterFieldType.Select,
            Options = 
            [
                new SelectOption<string>("Active", "Active"),
