        public string? AvatarUrl { get; set; }
        public IReadOnlyList<ITag> Tags { get; set; } = Array.Empty<ITag>();
    }

    private class SimpleTag : ITag
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string Color { get; set; } = "";
