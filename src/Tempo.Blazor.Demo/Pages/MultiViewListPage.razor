@page "/multi-view-list"
@using Tempo.Blazor.Components.DataDisplay
@using Tempo.Blazor.Interfaces
@using Tempo.Blazor.Models

<PageTitle>Multi View List – Tempo.Blazor</PageTitle>

<!-- Page Header -->
<div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Multi View List</h1>
    <p class="text-slate-600 dark:text-slate-400">Flexible list component with table, card, and list views. Supports saved views, filtering, and search.</p>
</div>

<!-- Info Alert -->
<div class="p-4 mb-6 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl">
    <div class="flex items-center space-x-3">
        <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
            <p class="text-sm text-blue-800 dark:text-blue-200">
                MultiViewList with <strong>View Manager</strong> - Save and load custom views with filters.
            </p>
            <p class="text-xs text-blue-600 dark:text-blue-400 mt-1">
                Uses <code>ViewHttpProvider</code> for persistence. Requires Demo.Api.
            </p>
        </div>
    </div>
</div>

<!-- Multi View List with Views -->
<section class="demo-section">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Team Members</h2>
        <span class="px-2 py-0.5 text-xs font-medium bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 rounded-full">With Views</span>
    </div>
    
    <TmMultiViewList Items="_teamMembers"
                     ViewContext="team-members"
                     ViewProvider="_viewProvider"
                     ViewFilterDefinitions="_filterDefs"
                     ExternalFilterDefinitions="_filterDefs"
                     ShowExternalFilterBuilder="true"
                     ViewCanCreateTenantViews="true"
                     CurrentUserId="CurrentUserId"
                     CurrentTenantId="CurrentTenantId"
                     ShowSearch="true"
                     ShowViewSwitcher="true"
                     EmptyTitle="No team members found"
                     OnItemClick="OnItemClick" />
</section>

<!-- Simple Multi View List (without views) -->
<section class="demo-section mt-8">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Projects</h2>
        <span class="px-2 py-0.5 text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-full">Simple</span>
    </div>
    
    <TmMultiViewList Items="_projects"
                     ViewContext="demo-projects"
                     ShowSearch="true"
                     ShowViewSwitcher="true"
                     EmptyTitle="No projects found"
                     OnItemClick="OnItemClick" />
</section>

