@code {
    private ToastService _demoToastService = new ToastService();
    private bool _showInternal;
    private int _activeStep;
    private string _stepperSize = "Medium";
    private bool _stepperVertical = false;
    private bool _drawerRightOpen;
    private bool _drawerLeftOpen;
    private int _bulkCount;
    private int? _quantity = 1;
    private int? _amount = 100;
    private int? _days = 30;

    // Tabs demo state
    private string _tabLineActive = "overview";
    private string _tabPillActive = "day";
    private string _tabEncActive = "source";

    // Progress segments
    private List<ProgressSegment> _progressSegments = new()
    {
        new(45, "var(--tm-color-success-500)", "On time"),
        new(25, "var(--tm-color-warning-500)", "At risk"),
        new(15, "var(--tm-color-error-500)", "Overdue"),
    };

    // Dynamic Form demo
    private List<DynamicFieldDefinition> _dynamicFields = new()
    {
        new() { Name = "subject", FieldType = DynamicFieldType.Text, Label = "Subject", Required = true, Placeholder = "Enter subject" },
        new() { Name = "priority", FieldType = DynamicFieldType.Select, Label = "Priority", Options = new List<SelectOption<string>> { new("low", "Low"), new("medium", "Medium"), new("high", "High") } },
        new() { Name = "description", FieldType = DynamicFieldType.TextArea, Label = "Description", Placeholder = "Describe the issue..." },
        new() { Name = "dueDate", FieldType = DynamicFieldType.Date, Label = "Due Date" },
        new() { Name = "urgent", FieldType = DynamicFieldType.Checkbox, Label = "Mark as urgent" },
        new() { Name = "count", FieldType = DynamicFieldType.Number, Label = "Quantity", HelpText = "Number of items" },
    };

    private Dictionary<string, object?> _dynamicValues = new();

    private void FireMultipleToasts()
    {
        Toast.ShowSuccess("File uploaded.");
        Toast.ShowInfo("Processing started…");
        Toast.ShowWarning("Disk space low.");
    }

    private int _unreadCount => _notifications.Count(n => !n.IsRead);

    private List<DemoNotification> _notifications = new()
    {
        new("n1", "Deployment succeeded", "Build #142 deployed to production.", false),
        new("n2", "New comment", "Alice commented on PR #88.", false),
        new("n3", "Issue resolved", "Bug #301 was closed.", true),
    };

    private record DemoNotification(string Id, string Title, string? Body, bool IsRead,
        string? IconName = null, string? ActionUrl = null,
        NotificationSeverity Severity = NotificationSeverity.Info) : INotificationItem
    {
        public DateTimeOffset CreatedAt => DateTimeOffset.Now.AddMinutes(-new Random().Next(1, 60));
    }

    private void MarkAllRead() =>
        _notifications = _notifications
            .Select(n => n with { IsRead = true })
            .ToList();

    private void AddNotification()
    {
        var newId = $"n{_notifications.Count + 1}";
        _notifications.Insert(0, new DemoNotification(
            newId, 
            $"New notification {_notifications.Count + 1}", 
            "This is a dynamically added notification.", 
            false));
    }

    private List<DemoEntry> _timelineEntries = new()
    {
        new("e1", "status_change", "Alice", DateTimeOffset.Now.AddHours(-5), null, "Changed status to In Progress", false),
        new("e2", "comment", "Bob", DateTimeOffset.Now.AddHours(-3), null, "LGTM! Ready to merge.", false),
        new("e3", "internal_note", "System", DateTimeOffset.Now.AddHours(-1), null, "Auto-assigned to Alice.", true),
    };

    private record DemoEntry(
        string Id,
        string EntryType,
        string AuthorName,
        DateTimeOffset CreatedAt,
        string? AuthorAvatarUrl,
        string? PlainContent,
        bool IsInternal,
        string? HtmlContent = null,
        IReadOnlyDictionary<string, string>? Metadata = null) : ITimelineEntry;

    private List<DemoStep> _steps = new()
    {
        new("s1", "Account", "Set up your account details"),
        new("s2", "Profile", "Complete your profile"),
        new("s3", "Plan", "Choose a plan"),
        new("s4", "Confirm", "Review and confirm"),
    };

    private record DemoStep(string Id, string Label, string? Description, string? Icon = null)
        : IStepItem;
}
