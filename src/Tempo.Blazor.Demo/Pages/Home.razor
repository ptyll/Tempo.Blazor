@page "/"
@inject NavigationManager Nav
<PageTitle>Tempo.Blazor - Modern Blazor Component Library</PageTitle>

<!-- Hero Section -->
<div class="text-center mb-16">
    <div class="inline-flex items-center space-x-2 px-4 py-2 rounded-full bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 text-sm font-medium mb-6">
        <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary-500"></span>
        </span>
        <span>80+ Production-Ready Components</span>
    </div>
    
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-white mb-6 tracking-tight">
        Build better apps with
        <span class="bg-gradient-to-r from-primary-600 to-primary-400 bg-clip-text text-transparent">
            Tempo.Blazor
        </span>
    </h1>
    
    <p class="text-lg sm:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto mb-8 leading-relaxed">
        A comprehensive, accessible, and customizable Blazor component library designed for modern web applications.
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <button @onclick='() => Nav.NavigateTo("buttons")' 
                class="group px-8 py-3.5 rounded-xl bg-primary-600 hover:bg-primary-700 text-white font-semibold shadow-lg shadow-primary-600/25 hover:shadow-primary-600/40 transition-all duration-200 flex items-center space-x-2">
            <span>Explore Components</span>
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
        </button>
        <button @onclick='() => Nav.NavigateTo("design-tokens")' 
                class="px-8 py-3.5 rounded-xl bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 font-semibold hover:border-primary-300 dark:hover:border-primary-700 hover:bg-primary-50 dark:hover:bg-primary-900/20 transition-all duration-200">
            Design Tokens
        </button>
    </div>
</div>

<!-- Features Grid -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
    <div class="group p-6 rounded-2xl bg-white dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700/50 hover:border-primary-200 dark:hover:border-primary-700/50 transition-all duration-200 hover:shadow-lg hover:shadow-slate-200/50 dark:hover:shadow-none">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mb-4 shadow-lg shadow-blue-500/25">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">Lightning Fast</h3>
        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            Optimized for performance with minimal overhead. Components are designed to render efficiently in Blazor WebAssembly.
        </p>
    </div>
    
    <div class="group p-6 rounded-2xl bg-white dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700/50 hover:border-primary-200 dark:hover:border-primary-700/50 transition-all duration-200 hover:shadow-lg hover:shadow-slate-200/50 dark:hover:shadow-none">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-purple-600 flex items-center justify-center mb-4 shadow-lg shadow-purple-500/25">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
            </svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">Fully Themable</h3>
        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            Complete design system with CSS custom properties. Light and dark mode support built-in with easy customization.
        </p>
    </div>
    
    <div class="group p-6 rounded-2xl bg-white dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700/50 hover:border-primary-200 dark:hover:border-primary-700/50 transition-all duration-200 hover:shadow-lg hover:shadow-slate-200/50 dark:hover:shadow-none">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-green-500 to-green-600 flex items-center justify-center mb-4 shadow-lg shadow-green-500/25">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">Accessible</h3>
        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            WCAG 2.1 AA compliant components with proper ARIA labels, keyboard navigation, and screen reader support.
        </p>
    </div>
</div>

<!-- Components Showcase -->
<div class="mb-8">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">Component Showcase</h2>
            <p class="text-slate-600 dark:text-slate-400">Explore our comprehensive collection of UI components</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var card in ComponentCards)
        {
            <a href="@card.Href" class="group block">
                <div class="relative p-6 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:border-primary-300 dark:hover:border-primary-700 transition-all duration-200 hover:shadow-xl hover:shadow-slate-200/50 dark:hover:shadow-none hover:-translate-y-1">
                    <!-- Icon -->
                    <div class="w-12 h-12 rounded-xl @card.GradientClass flex items-center justify-center mb-4 shadow-lg transition-transform duration-200 group-hover:scale-110">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            @((MarkupString)card.Icon)
                        </svg>
                    </div>
                    
                    <!-- Content -->
                    <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                        @card.Title
                    </h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
                        @card.Description
                    </p>
                    
                    <!-- Arrow -->
                    <div class="flex items-center text-sm font-medium text-primary-600 dark:text-primary-400 opacity-0 group-hover:opacity-100 transition-opacity">
                        <span>View components</span>
                        <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                        </svg>
                    </div>
                    
                    <!-- Hover gradient -->
                    <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-primary-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
                </div>
            </a>
        }
    </div>
</div>

<!-- Stats Section -->
<div class="mt-16 p-8 rounded-2xl bg-gradient-to-br from-slate-900 to-slate-800 dark:from-slate-800 dark:to-slate-900 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-0 right-0 -mt-20 -mr-20 w-64 h-64 bg-primary-500/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 -mb-20 -ml-20 w-64 h-64 bg-blue-500/20 rounded-full blur-3xl"></div>
    
    <div class="relative grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
            <div class="text-3xl md:text-4xl font-bold text-white mb-1">80+</div>
            <div class="text-slate-400 text-sm">Components</div>
        </div>
        <div>
            <div class="text-3xl md:text-4xl font-bold text-white mb-1">100%</div>
            <div class="text-slate-400 text-sm">TypeScript</div>
        </div>
        <div>
            <div class="text-3xl md:text-4xl font-bold text-white mb-1">2</div>
            <div class="text-slate-400 text-sm">Languages</div>
        </div>
        <div>
            <div class="text-3xl md:text-4xl font-bold text-white mb-1">∞</div>
            <div class="text-slate-400 text-sm">Possibilities</div>
        </div>
    </div>
</div>

@code {
    private record ComponentCard(string Href, string Title, string Description, string Icon, string GradientClass);

    private ComponentCard[] ComponentCards = new[]
    {
        new ComponentCard("buttons", "Buttons & Spinners", 
            "TmButton with variants, sizes, loading states, TmSpinner, TmSkeleton loaders",
            "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122\" />",
            "bg-gradient-to-br from-primary-500 to-primary-600"),
        
        new ComponentCard("forms", "Form Inputs", 
            "TmTextInput, TmSelect, TmCheckbox, TmToggle, TmRadioGroup, TmSearchInput",
            "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01\" />",
            "bg-gradient-to-br from-blue-500 to-blue-600"),
        
        new ComponentCard("data-display", "Data Display", 
            "TmBadge, TmCard, TmStatCard, TmEmptyState, TmAvatar with groups",
            "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z\" />",
            "bg-gradient-to-br from-green-500 to-green-600"),
        
        new ComponentCard("data-table", "Data Table", 
            "TmDataTable with typed columns, loading states, empty state, row click handlers",
            "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z\" />",
            "bg-gradient-to-br from-purple-500 to-purple-600"),
        
        new ComponentCard("feedback", "Feedback", 
            "TmNotificationBell, TmTimeline, TmStepper for user feedback and workflows",
            "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" />",
            "bg-gradient-to-br from-orange-500 to-orange-600"),
        
        new ComponentCard("pickers", "Pickers & Files", 
            "TmTagPicker, TmFileDropZone, TmDropdown, TmFilterableDropdown components",
            "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z\" />",
            "bg-gradient-to-br from-pink-500 to-pink-600"),
        
        new ComponentCard("gallery", "Image Gallery", 
            "TmImageGallery with thumbnail grid, empty state, loading skeletons",
            "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z\" />",
            "bg-gradient-to-br from-cyan-500 to-cyan-600"),
        
        new ComponentCard("tree-view", "Tree View", 
            "TmTreeView with expandable nodes, lazy loading, and node selection",
            "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11\" />",
            "bg-gradient-to-br from-emerald-500 to-emerald-600"),
        
        new ComponentCard("activity", "Activity", 
            "TmActivityLog, TmActivityTimeline, TmActivityComments, TmRichTextEditor",
            "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\" />",
            "bg-gradient-to-br from-amber-500 to-amber-600"),
        
        new ComponentCard("toolbar-forms", "Toolbar & Forms", 
            "TmToolbar, TmToolbarButton, TmFormSection, TmFormRow, TmFormField layouts",
            "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6h16M4 12h16M4 18h16\" />",
            "bg-gradient-to-br from-rose-500 to-rose-600"),
        
        new ComponentCard("design-tokens", "Design Tokens", 
            "Colors, typography, spacing, radius, shadows, animations, dark mode support",
            "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01\" />",
            "bg-gradient-to-br from-indigo-500 to-indigo-600"),
    };
}
