@page "/layout"
@using Tempo.Blazor.Components.Layout
@using Tempo.Blazor.Components.Buttons
@using Tempo.Blazor.Components.Icons
@using Tempo.Blazor.Components.Feedback
@using Tempo.Blazor.Components.DataDisplay
@using Tempo.Blazor.Models
@using Tempo.Blazor.Interfaces
@inject ToastService Toast
@inject NavigationManager Navigation

<PageTitle>Layout Components – Tempo.Blazor</PageTitle>

<!-- Page Header -->
<div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Layout Components</h1>
    <p class="text-slate-600 dark:text-slate-400">Navigation, sidebar, breadcrumbs, and command palette for application layout.</p>
</div>

<!-- Breadcrumbs Section -->
<section class="demo-section">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Breadcrumbs</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">Navigation path indicator with clickable segments</p>
        </div>
        <span class="px-2 py-0.5 text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-full">Navigation</span>
    </div>
    
    <div class="showcase-card space-y-4">
        <div>
            <p class="text-sm text-slate-500 mb-2">Simple breadcrumbs</p>
            <TmBreadcrumbs Items="_simpleBreadcrumbs" />
        </div>
        
        <div>
            <p class="text-sm text-slate-500 mb-2">With icons and home</p>
            <TmBreadcrumbs Items="_fullBreadcrumbs" />
        </div>
        
        <div>
            <p class="text-sm text-slate-500 mb-2">Custom separator</p>
            <TmBreadcrumbs Items="_simpleBreadcrumbs" Separator="→" />
        </div>
        
        <div>
            <p class="text-sm text-slate-500 mb-2">With click action (no navigation)</p>
            <TmBreadcrumbs Items="_clickableBreadcrumbs" OnItemClick="OnBreadcrumbClick" />
            @if (_clickedBreadcrumb is not null)
            {
                <p class="mt-2 text-sm text-green-600 dark:text-green-400">
                    Clicked: <strong>@_clickedBreadcrumb</strong>
                </p>
            }
        </div>
    </div>
</section>

<!-- Sidebar Section -->
<section class="demo-section">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Sidebar</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">Collapsible navigation sidebar with nested menu items</p>
        </div>
        <span class="px-2 py-0.5 text-xs font-medium bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 rounded-full">Layout</span>
    </div>
    
    <div class="showcase-card">
        <div class="flex gap-4">
            <TmButton Variant="ButtonVariant.Primary" OnClick="() => _sidebarCollapsed = false">
                Expand Sidebar
            </TmButton>
            <TmButton Variant="ButtonVariant.Secondary" OnClick="() => _sidebarCollapsed = true">
                Collapse Sidebar
            </TmButton>
        </div>
        
        <div class="mt-4 p-4 bg-slate-50 dark:bg-slate-800 rounded-lg">
            <p class="text-sm text-slate-600 dark:text-slate-400 mb-2">
                Current state: <code class="px-1.5 py-0.5 bg-slate-200 dark:bg-slate-700 rounded">@(_sidebarCollapsed ? "Collapsed" : "Expanded")</code>
            </p>
        </div>
        
        <!-- Demo Sidebar -->
        <div class="mt-4 border border-slate-200 dark:border-slate-700 rounded-lg overflow-hidden" style="height: 300px;">
            <TmSidebar Items="_sidebarItems"
                      Collapsed="_sidebarCollapsed"
                      OnToggle="() => _sidebarCollapsed = !_sidebarCollapsed"
                      Class="h-full">
                <Header>
                    <div class="flex items-center gap-2 px-4 py-3 border-b border-slate-200 dark:border-slate-700">
                        <TmIcon Name="layers" />
                        @if (!_sidebarCollapsed)
                        {
                            <span class="font-semibold">Tempo.Blazor</span>
                        }
                    </div>
                </Header>
            </TmSidebar>
        </div>
    </div>
</section>

<!-- TopBar Section -->
<section class="demo-section">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">TopBar</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">Application header with search, notifications, and user menu</p>
        </div>
        <span class="px-2 py-0.5 text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 rounded-full">Layout</span>
    </div>
    
    <div class="showcase-card p-0 overflow-hidden">
        <TmTopBar BrandTitle="Tempo.Blazor Demo" 
                  OnCommandPalette="() => _commandPaletteOpen = true">
            <ActionsContent>
                <TmButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" Icon="@IconNames.Bell" OnClick='() => Toast.ShowInfo("Notifications clicked")' />
                <TmButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" Icon="@IconNames.User" OnClick='() => Toast.ShowInfo("Profile clicked")' />
            </ActionsContent>
        </TmTopBar>
        
        <div class="p-4">
            <p class="text-sm text-slate-600 dark:text-slate-400">
                Click the search button (⌘K) or user icons in the top bar.
            </p>
        </div>
    </div>
</section>

<!-- Command Palette Section -->
<section class="demo-section">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Command Palette</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">Quick command search with keyboard shortcut (Ctrl+K)</p>
        </div>
        <span class="px-2 py-0.5 text-xs font-medium bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300 rounded-full">Navigation</span>
    </div>
    
    <div class="showcase-card">
        <div class="flex items-center gap-4">
            <TmButton Variant="ButtonVariant.Primary" OnClick="() => _commandPaletteOpen = true">
                <TmIcon Name="search" class="mr-2" />
                Open Command Palette
            </TmButton>
            <span class="text-sm text-slate-500">or press <kbd class="px-2 py-1 bg-slate-100 dark:bg-slate-800 rounded border border-slate-300 dark:border-slate-600 font-mono text-xs">Ctrl+K</kbd></span>
        </div>
        
        <div class="mt-4 p-4 bg-slate-50 dark:bg-slate-800 rounded-lg">
            <p class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Available Commands:</p>
            <div class="flex flex-wrap gap-2">
                @foreach (var cmd in _availableActions.Take(6))
                {
                    <TmBadge Variant="BadgeVariant.Default">@cmd.Title</TmBadge>
                }
                @if (_availableActions.Count > 6)
                {
                    <TmBadge Variant="BadgeVariant.Info">+@(_availableActions.Count - 6) more</TmBadge>
                }
            </div>
        </div>
        
        @if (!string.IsNullOrEmpty(_lastCommand))
        {
            <div class="mt-4 p-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
                <p class="text-sm text-green-800 dark:text-green-200">
                    Last executed: <strong>@_lastCommand</strong>
                </p>
            </div>
        }
    </div>
    
    <TmCommandPalette @bind-IsOpen="_commandPaletteOpen"
                      Actions="_availableActions" />
</section>

<!-- Combined Layout Demo -->
<section class="demo-section">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Combined Layout</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">All layout components working together</p>
        </div>
        <span class="px-2 py-0.5 text-xs font-medium bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 rounded-full">Demo</span>
    </div>
    
    <div class="showcase-card p-0 overflow-hidden" style="height: 400px;">
        <div class="h-full flex">
            <!-- Mini Sidebar -->
            <div class="w-16 bg-slate-900 dark:bg-slate-950 flex flex-col items-center py-4 gap-4 border-r border-slate-800">
                <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center text-white font-bold">T</div>
                <div class="w-10 h-10 rounded-lg bg-blue-600/20 flex items-center justify-center text-blue-400 cursor-pointer">
                    <TmIcon Name="home" />
                </div>
                <div class="w-10 h-10 rounded-lg hover:bg-slate-800 flex items-center justify-center text-slate-400 cursor-pointer">
                    <TmIcon Name="users" />
                </div>
                <div class="w-10 h-10 rounded-lg hover:bg-slate-800 flex items-center justify-center text-slate-400 cursor-pointer">
                    <TmIcon Name="settings" />
                </div>
            </div>
            
            <!-- Content Area -->
            <div class="flex-1 flex flex-col bg-slate-50 dark:bg-slate-900">
                <!-- Mini TopBar -->
                <div class="h-14 bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 flex items-center justify-between px-4">
                    <div class="flex items-center gap-4">
                        <TmBreadcrumbs Items="_demoBreadcrumbs" />
                    </div>
                    <div class="flex items-center gap-2">
                        <TmButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" Icon="search" OnClick="() => _commandPaletteOpen = true" />
                        <TmButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" Icon="bell" />
                        <TmAvatar Name="John Doe" Size="AvatarSize.Sm" />
                    </div>
                </div>
                
                <!-- Page Content -->
                <div class="flex-1 p-6">
                    <div class="grid grid-cols-3 gap-4">
                        <TmCard Header="Card 1" class="h-32">
                            <p class="text-sm text-slate-500">Sample content</p>
                        </TmCard>
                        <TmCard Header="Card 2" class="h-32">
                            <p class="text-sm text-slate-500">Sample content</p>
                        </TmCard>
                        <TmCard Header="Card 3" class="h-32">
                            <p class="text-sm text-slate-500">Sample content</p>
                        </TmCard>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private bool _sidebarCollapsed = false;
    private bool _commandPaletteOpen = false;
    private string? _lastCommand;
    
    private List<ISidebarNavItem> _sidebarItems = new()
    {
        new SidebarNavItem("1", "Dashboard", "home", "/"),
        new SidebarNavItem("2", "Users", "users", "/datatable"),
        new SidebarNavItem("3", "Settings", "settings", "/forms", children: new()
        {
            new SidebarNavItem("3-1", "General", null!, "/forms"),
            new SidebarNavItem("3-2", "Security", null!, "/feedback"),
            new SidebarNavItem("3-3", "Notifications", null!, "/pickers")
        }),
        new SidebarNavItem("4", "Help", "help-circle", "/")
    };

    private List<IBreadcrumbItem> _simpleBreadcrumbs = new()
    {
        new BreadcrumbItem("Home", "/"),
        new BreadcrumbItem("Products", "/datatable"),
        new BreadcrumbItem("Electronics", null)
    };

    private List<IBreadcrumbItem> _fullBreadcrumbs = new()
    {
        new BreadcrumbItem("Home", "/", "home"),
        new BreadcrumbItem("Users", "/datatable", "users"),
        new BreadcrumbItem("John Doe", null, "user")
    };

    private List<IBreadcrumbItem> _demoBreadcrumbs = new()
    {
        new BreadcrumbItem("Dashboard", "/"),
        new BreadcrumbItem("Settings", "/forms"),
        new BreadcrumbItem("Profile", null)
    };

    private List<IBreadcrumbItem> _clickableBreadcrumbs = new()
    {
        new BreadcrumbItem("Home", null, "home"),
        new BreadcrumbItem("Products", null, "package"),
        new BreadcrumbItem("Electronics", null, "cpu")
    };

    private string? _clickedBreadcrumb;

    private List<ICommandPaletteAction> _availableActions = new();

    protected override void OnInitialized()
    {
        _availableActions = new List<ICommandPaletteAction>
        {
            new CommandPaletteAction("home", "Go to Dashboard", "Navigate to home page", "home", async () => await ExecuteCommand("home", "/")),
            new CommandPaletteAction("users", "Go to Users", "View user list", "users", async () => await ExecuteCommand("users", "/datatable")),
            new CommandPaletteAction("forms", "Go to Forms", "Form components demo", "file-text", async () => await ExecuteCommand("forms", "/forms")),
            new CommandPaletteAction("feedback", "Go to Feedback", "Alerts, toasts, and notifications", "bell", async () => await ExecuteCommand("feedback", "/feedback")),
            new CommandPaletteAction("pickers", "Go to Pickers", "Date and time pickers", "calendar", async () => await ExecuteCommand("pickers", "/pickers")),
            new CommandPaletteAction("richtext", "Go to Rich Text", "Text editors", "type", async () => await ExecuteCommand("richtext", "/richtext")),
            new CommandPaletteAction("gallery", "Go to Gallery", "Image gallery", "image", async () => await ExecuteCommand("gallery", "/gallery")),
            new CommandPaletteAction("layout", "Go to Layout", "Layout components", "layout", async () => await ExecuteCommand("layout", "/layout")),
            new CommandPaletteAction("toast", "Show Toast Notification", "Display a sample toast", "bell", async () => await ShowToastCommand()),
        };
    }

    private async Task ExecuteCommand(string name, string url)
    {
        _lastCommand = $"Navigate to {name}";
        Navigation.NavigateTo(url);
        await Task.CompletedTask;
    }

    private async Task ShowToastCommand()
    {
        _lastCommand = "Show Toast Notification";
        Toast.ShowSuccess("This is a sample toast notification!");
        await Task.CompletedTask;
    }

    private void OnBreadcrumbClick(IBreadcrumbItem item)
    {
        _clickedBreadcrumb = item.Label;
        Toast.ShowInfo($"Breadcrumb clicked: {item.Label}");
    }

    // Simple implementation of ICommandPaletteAction
    private class CommandPaletteAction : ICommandPaletteAction
    {
        public string Id { get; }
        public string Title { get; }
        public string? Description { get; }
        public string? Icon { get; }
        public string? Shortcut { get; }
        public string? Category { get; }
        public Func<Task> Execute { get; }

        public CommandPaletteAction(string id, string title, string? description = null, string? icon = null, Func<Task>? execute = null)
        {
            Id = id;
            Title = title;
            Description = description;
            Icon = icon;
            Execute = execute ?? (() => Task.CompletedTask);
        }
    }

    // Simple implementation of ISidebarNavItem
    private class SidebarNavItem : ISidebarNavItem
    {
        public string Id { get; }
        public string Label { get; }
        public string Icon { get; }
        public string Href { get; }
        public int? BadgeCount { get; }
        public bool IsActive { get; }
        public IReadOnlyList<ISidebarNavItem>? Children { get; }

        public SidebarNavItem(string id, string label, string? icon, string href, int? badgeCount = null, bool isActive = false, List<ISidebarNavItem>? children = null)
        {
            Id = id;
            Label = label;
            Icon = icon ?? string.Empty;
            Href = href;
            BadgeCount = badgeCount;
            IsActive = isActive;
            Children = children;
        }
    }
}
