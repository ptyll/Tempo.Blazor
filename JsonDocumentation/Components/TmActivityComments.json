{
  "itemName": "TmActivityComments",
  "kind": "Component",
  "category": "Activity",
  "description": "Comment thread component with inline rich text editing via TmRichEditorSimple. Supports adding, editing, and deleting comments with author avatars, relative timestamps, and edit indicators. Communicates changes via EventCallbacks.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Activity"
  ],
  "parameters": [
    {
      "name": "Comments",
      "type": "IReadOnlyList<ICommentEntry>",
      "isRequired": false,
      "default": "[]"
    },
    {
      "name": "OnCommentAdded",
      "type": "EventCallback<string>",
      "isRequired": false
    },
    {
      "name": "OnCommentDeleted",
      "type": "EventCallback<string>",
      "isRequired": false
    },
    {
      "name": "OnCommentEdited",
      "type": "EventCallback<(string Id, string Html)>",
      "isRequired": false
    },
    {
      "name": "ShowAddButton",
      "type": "bool",
      "isRequired": false,
      "default": "true"
    }
  ],
  "cssClasses": [
    "tm-comments",
    "tm-comments-empty",
    "tm-comment-list",
    "tm-comment-item",
    "tm-comment-avatar",
    "tm-comment-body",
    "tm-comment-meta",
    "tm-comment-author",
    "tm-comment-time",
    "tm-comment-edited",
    "tm-comment-content",
    "tm-comment-actions",
    "tm-comment-editor",
    "tm-comment-editor-actions",
    "tm-comments-add-btn"
  ],
  "examples": [
    {
      "title": "Comment section with add/edit/delete",
      "code": "<TmActivityComments Comments=\"@comments\"\n                     OnCommentAdded=\"HandleAdd\"\n                     OnCommentDeleted=\"HandleDelete\"\n                     OnCommentEdited=\"HandleEdit\"\n                     ShowAddButton=\"true\" />"
    }
  ]
}