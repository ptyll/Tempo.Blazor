{
  "itemName": "TmNumberInput",
  "kind": "Component",
  "category": "Inputs",
  "description": "Numeric input with increment/decrement buttons, min/max constraints, step control, prefix/suffix text (e.g. currency symbols, units), and error/help text.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Inputs"
  ],
  "parameters": [
    {
      "name": "Value",
      "type": "int?",
      "isRequired": false,
      "description": "Current numeric value."
    },
    {
      "name": "ValueChanged",
      "type": "EventCallback<int?>",
      "isRequired": false,
      "description": "Fires when value changes."
    },
    {
      "name": "Min",
      "type": "int?",
      "isRequired": false,
      "description": "Minimum allowed value."
    },
    {
      "name": "Max",
      "type": "int?",
      "isRequired": false,
      "description": "Maximum allowed value."
    },
    {
      "name": "Step",
      "type": "int",
      "isRequired": false,
      "default": "1",
      "description": "Step increment/decrement (default 1)."
    },
    {
      "name": "Label",
      "type": "string?",
      "isRequired": false,
      "description": "Field label."
    },
    {
      "name": "Placeholder",
      "type": "string?",
      "isRequired": false,
      "description": "Placeholder text."
    },
    {
      "name": "Error",
      "type": "string?",
      "isRequired": false,
      "description": "Error message."
    },
    {
      "name": "HelpText",
      "type": "string?",
      "isRequired": false,
      "description": "Help text below the input."
    },
    {
      "name": "Disabled",
      "type": "bool",
      "isRequired": false,
      "description": "Disable the input."
    },
    {
      "name": "ShowButtons",
      "type": "bool",
      "isRequired": false,
      "default": "true",
      "description": "Show +/- buttons (default true)."
    },
    {
      "name": "Prefix",
      "type": "string?",
      "isRequired": false,
      "description": "Prefix text (e.g. \"$\")."
    },
    {
      "name": "Suffix",
      "type": "string?",
      "isRequired": false,
      "description": "Suffix text (e.g. \"days\")."
    },
    {
      "name": "AutoComplete",
      "type": "string?",
      "isRequired": false,
      "description": "HTML autocomplete attribute. Common values: \"on\", \"off\"."
    },
    {
      "name": "Class",
      "type": "string?",
      "isRequired": false,
      "description": "Additional CSS class(es)."
    }
  ],
  "cssClasses": [
    "tm-input-wrapper",
    "tm-number-input",
    "tm-number-input--disabled",
    "tm-number-input--error",
    "tm-number-input__input",
    "tm-number-input__increment",
    "tm-number-input__decrement",
    "tm-number-input__prefix",
    "tm-number-input__suffix",
    "tm-input-error-message",
    "tm-input-help-text"
  ],
  "examples": [
    {
      "title": "Basic number input",
      "code": "<TmNumberInput @bind-Value=\"quantity\" Label=\"Quantity\" Min=\"1\" Max=\"100\" />"
    },
    {
      "title": "Number input with prefix and suffix",
      "code": "<TmNumberInput @bind-Value=\"price\" Label=\"Price\" Prefix=\"$\" Suffix=\"USD\" Step=\"5\" Min=\"0\" Max=\"10000\" />"
    },
    {
      "title": "Number input without buttons",
      "code": "<TmNumberInput @bind-Value=\"age\" Label=\"Age\" ShowButtons=\"false\" Placeholder=\"Enter age\" />"
    }
  ]
}