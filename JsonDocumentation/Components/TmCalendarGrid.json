{
  "itemName": "TmCalendarGrid",
  "kind": "Component",
  "category": "Pickers",
  "description": "Reusable calendar month grid with day selection, range highlighting, today indicator, and month navigation. Used internally by TmDatePicker and TmDateRangePicker.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Pickers"
  ],
  "parameters": [
    {
      "name": "DisplayYear",
      "type": "int",
      "isRequired": false,
      "default": "DateTime.Today.Year"
    },
    {
      "name": "DisplayMonth",
      "type": "int",
      "isRequired": false,
      "default": "DateTime.Today.Month"
    },
    {
      "name": "SelectedDate",
      "type": "DateOnly?",
      "isRequired": false
    },
    {
      "name": "RangeStart",
      "type": "DateOnly?",
      "isRequired": false
    },
    {
      "name": "RangeEnd",
      "type": "DateOnly?",
      "isRequired": false
    },
    {
      "name": "HoverDate",
      "type": "DateOnly?",
      "isRequired": false
    },
    {
      "name": "MinDate",
      "type": "DateOnly?",
      "isRequired": false
    },
    {
      "name": "MaxDate",
      "type": "DateOnly?",
      "isRequired": false
    },
    {
      "name": "OnDateSelected",
      "type": "EventCallback<DateOnly>",
      "isRequired": false
    },
    {
      "name": "OnDateHovered",
      "type": "EventCallback<DateOnly>",
      "isRequired": false
    },
    {
      "name": "OnNavigate",
      "type": "EventCallback<(int Year, int Month)>",
      "isRequired": false
    }
  ],
  "cssClasses": [
    "tm-calendar",
    "tm-cal-nav",
    "tm-cal-nav-btn",
    "tm-cal-prev",
    "tm-cal-next",
    "tm-cal-title",
    "tm-cal-grid",
    "tm-cal-header-cell",
    "tm-cal-day",
    "tm-cal-day--other-month",
    "tm-cal-day--today",
    "tm-cal-day--selected",
    "tm-cal-day--range-start",
    "tm-cal-day--range-end",
    "tm-cal-day--in-range",
    "tm-cal-day--disabled"
  ],
  "examples": [
    {
      "title": "Standalone calendar grid",
      "code": "<TmCalendarGrid DisplayYear=\"2026\" DisplayMonth=\"3\"\n                SelectedDate=\"@selectedDate\"\n                OnDateSelected=\"HandleDateSelected\"\n                OnNavigate=\"HandleNavigate\" />"
    },
    {
      "title": "Calendar grid with range selection",
      "code": "<TmCalendarGrid DisplayYear=\"2026\" DisplayMonth=\"3\"\n                RangeStart=\"@rangeStart\" RangeEnd=\"@rangeEnd\"\n                MinDate=\"@(new DateOnly(2026, 1, 1))\"\n                OnDateSelected=\"HandleDateSelected\"\n                OnNavigate=\"HandleNavigate\" />"
    }
  ]
}