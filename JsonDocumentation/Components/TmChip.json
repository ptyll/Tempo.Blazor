{
  "itemName": "TmChip",
  "kind": "Component",
  "category": "Data Display",
  "description": "Small labelled element with Soft, Filled, and Outlined variants, optional icon, removable close button, clickable/selectable states, custom color via CSS variable, and two sizes.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.DataDisplay"
  ],
  "parameters": [
    {
      "name": "Color",
      "type": "string?",
      "isRequired": false,
      "description": "Custom CSS color."
    },
    {
      "name": "Variant",
      "type": "ChipVariant",
      "isRequired": false,
      "default": "Soft",
      "description": "Visual variant."
    },
    {
      "name": "Size",
      "type": "ChipSize",
      "isRequired": false,
      "default": "Md",
      "description": "Chip size."
    },
    {
      "name": "Icon",
      "type": "string?",
      "isRequired": false,
      "description": "Optional icon name."
    },
    {
      "name": "Removable",
      "type": "bool",
      "isRequired": false,
      "description": "Show remove button."
    },
    {
      "name": "OnRemove",
      "type": "EventCallback",
      "isRequired": false,
      "description": "Fires when remove is clicked."
    },
    {
      "name": "Clickable",
      "type": "bool",
      "isRequired": false,
      "description": "Make the chip clickable."
    },
    {
      "name": "OnClick",
      "type": "EventCallback",
      "isRequired": false,
      "description": "Fires when chip is clicked."
    },
    {
      "name": "Selected",
      "type": "bool",
      "isRequired": false,
      "description": "Whether the chip is selected."
    },
    {
      "name": "Disabled",
      "type": "bool",
      "isRequired": false,
      "description": "Whether the chip is disabled."
    },
    {
      "name": "Class",
      "type": "string?",
      "isRequired": false,
      "description": "Additional CSS class."
    }
  ],
  "cssClasses": [
    "tm-chip",
    "tm-chip--soft",
    "tm-chip--filled",
    "tm-chip--outlined",
    "tm-chip--sm",
    "tm-chip--md",
    "tm-chip--clickable",
    "tm-chip--selected",
    "tm-chip__icon",
    "tm-chip__label",
    "tm-chip__remove"
  ],
  "examples": [
    {
      "title": "Removable chip",
      "code": "<TmChip Label=\"JavaScript\" Removable=\"true\" OnRemove=\"() => RemoveTag(\"JavaScript\")\" />"
    },
    {
      "title": "Clickable chip with icon and custom color",
      "code": "<TmChip Label=\"Priority: High\"\n        Icon=\"flag\"\n        Color=\"#ef4444\"\n        Variant=\"ChipVariant.Filled\"\n        Clickable=\"true\"\n        Selected=\"@isSelected\"\n        OnClick=\"ToggleSelection\" />"
    }
  ]
}