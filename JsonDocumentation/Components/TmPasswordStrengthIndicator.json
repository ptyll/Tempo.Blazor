  "requiredImports": [
    "@using Tempo.Blazor.Components.Inputs"
  ],
  "cssClasses": [
    "tm-password-strength",
    "tm-password-strength-bar",
    "tm-password-strength-fill",
    "tm-strength-0",
    "tm-strength-1",
    "tm-strength-2",
    "tm-strength-3",
    "tm-strength-4",
    "tm-strength-5",
    "tm-password-strength-info",
    "tm-password-strength-text",
    "tm-password-strength-hint"
  ],
  "examples": [
    {
      "title": "Password strength indicator",
      "code": "<TmTextInput @bind-Value=\"password\" Label=\"Password\" Type=\"password\" />\n<TmPasswordStrengthIndicator Password=\"@password\" />"
    }
  ]
}