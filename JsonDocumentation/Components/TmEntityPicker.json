{
  "itemName": "TmEntityPicker",
  "kind": "Component",
  "category": "Inputs",
  "description": "Searchable entity lookup input that calls an async search provider after a configurable debounce, displays results in a dropdown, and binds to a typed value upon selection.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Inputs"
  ],
  "parameters": [
    {
      "name": "Value",
      "type": "TValue?",
      "isRequired": false,
      "description": "Current selected value."
    },
    {
      "name": "ValueChanged",
      "type": "EventCallback<TValue?>",
      "isRequired": false,
      "description": "Fires when value changes."
    },
    {
      "name": "Label",
      "type": "string?",
      "isRequired": false,
      "description": "Field label."
    },
    {
      "name": "Placeholder",
      "type": "string?",
      "isRequired": false,
      "description": "Placeholder text."
    },
    {
      "name": "MinSearchLength",
      "type": "int",
      "isRequired": false,
      "default": "2",
      "description": "Minimum characters before search triggers."
    },
    {
      "name": "Debounce",
      "type": "int",
      "isRequired": false,
      "default": "300",
      "description": "Debounce delay in ms."
    },
    {
      "name": "Error",
      "type": "string?",
      "isRequired": false,
      "description": "Error message."
    },
    {
      "name": "Class",
      "type": "string?",
      "isRequired": false,
      "description": "Additional CSS class(es)."
    },
    {
      "name": "Disabled",
      "type": "bool",
      "isRequired": false,
      "description": "Disable the input."
    }
  ],
  "cssClasses": [
    "tm-entity-picker",
    "tm-entity-picker--disabled",
    "tm-entity-picker__input-wrapper",
    "tm-entity-picker__search-icon",
    "tm-entity-picker__input",
    "tm-entity-picker__loading",
    "tm-entity-picker__dropdown",
    "tm-entity-picker__option",
    "tm-entity-picker__no-results"
  ],
  "examples": [
    {
      "title": "Entity picker for users",
      "code": "<TmEntityPicker TItem=\"UserDto\" TValue=\"Guid\" @bind-Value=\"selectedUserId\" SearchProvider=\"@SearchUsersAsync\" ValueSelector=\"@(u => u.Id)\" DisplaySelector=\"@(u => u.FullName)\" Label=\"Assigned To\" Placeholder=\"Search users...\" />"
    },
    {
      "title": "Entity picker with custom debounce and min search length",
      "code": "<TmEntityPicker TItem=\"CompanyDto\" TValue=\"int\" @bind-Value=\"companyId\" SearchProvider=\"@SearchCompaniesAsync\" ValueSelector=\"@(c => c.Id)\" DisplaySelector=\"@(c => c.Name)\" Label=\"Company\" MinSearchLength=\"3\" Debounce=\"500\" />"
    }
  ]
}