{
  "itemName": "TmPopover",
  "kind": "Component",
  "category": "Feedback",
  "description": "Rich content popup anchored to a trigger element with configurable position (Top, Bottom, Left, Right), optional arrow, and controlled/uncontrolled open state. Closes on Escape key.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Feedback"
  ],
  "parameters": [
    {
      "name": "Position",
      "type": "PopoverPosition",
      "isRequired": false,
      "default": "Bottom",
      "description": "Position relative to trigger."
    },
    {
      "name": "IsOpen",
      "type": "bool?",
      "isRequired": false,
      "description": "Controlled open state."
    },
    {
      "name": "IsOpenChanged",
      "type": "EventCallback<bool>",
      "isRequired": false,
      "description": "Fires when open state changes."
    },
    {
      "name": "ShowArrow",
      "type": "bool",
      "isRequired": false,
      "default": "true",
      "description": "Show arrow pointing to trigger."
    },
    {
      "name": "CloseOnClickOutside",
      "type": "bool",
      "isRequired": false,
      "default": "true",
      "description": "Close when clicking outside."
    },
    {
      "name": "Class",
      "type": "string?",
      "isRequired": false,
      "description": "Additional CSS class."
    }
  ],
  "cssClasses": [
    "tm-popover",
    "tm-popover--top",
    "tm-popover--bottom",
    "tm-popover--left",
    "tm-popover--right",
    "tm-popover__trigger",
    "tm-popover__body",
    "tm-popover__body--open",
    "tm-popover__arrow"
  ],
  "examples": [
    {
      "title": "Basic popover",
      "code": "<TmPopover Position=\"PopoverPosition.Bottom\">\n    <TriggerContent>\n        <TmButton>Show details</TmButton>\n    </TriggerContent>\n    <ChildContent>\n        <p>Additional information displayed in a popover.</p>\n    </ChildContent>\n</TmPopover>"
    },
    {
      "title": "Controlled popover without arrow",
      "code": "<TmPopover Position=\"PopoverPosition.Right\" ShowArrow=\"false\"\n    IsOpen=\"@isPopoverOpen\" IsOpenChanged=\"val => isPopoverOpen = val\">\n    <TriggerContent><span>Hover target</span></TriggerContent>\n    <ChildContent><p>Popover content</p></ChildContent>\n</TmPopover>"
    }
  ]
}