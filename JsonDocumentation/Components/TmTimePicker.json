{
  "itemName": "TmTimePicker",
  "kind": "Component",
  "category": "Pickers",
  "description": "Time picker wrapping TmTimeInput with label, placeholder, clear button, and validation styling for out-of-range values.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Pickers"
  ],
  "parameters": [
    {
      "name": "Value",
      "type": "TimeOnly?",
      "isRequired": false
    },
    {
      "name": "ValueChanged",
      "type": "EventCallback<TimeOnly?>",
      "isRequired": false
    },
    {
      "name": "MinTime",
      "type": "TimeOnly?",
      "isRequired": false
    },
    {
      "name": "MaxTime",
      "type": "TimeOnly?",
      "isRequired": false
    },
    {
      "name": "ShowSeconds",
      "type": "bool",
      "isRequired": false
    },
    {
      "name": "Placeholder",
      "type": "string?",
      "isRequired": false
    },
    {
      "name": "Disabled",
      "type": "bool",
      "isRequired": false
    },
    {
      "name": "Required",
      "type": "bool",
      "isRequired": false
    },
    {
      "name": "Label",
      "type": "string?",
      "isRequired": false
    },
    {
      "name": "Class",
      "type": "string?",
      "isRequired": false
    }
  ],
  "cssClasses": [
    "tm-time-picker",
    "tm-time-picker-body",
    "tm-time-picker--invalid",
    "tm-picker-label",
    "tm-picker-clear",
    "tm-picker-placeholder"
  ],
  "examples": [
    {
      "title": "Basic time picker",
      "code": "<TmTimePicker @bind-Value=\"selectedTime\" Label=\"Meeting time\" />"
    },
    {
      "title": "Time picker with seconds and constraints",
      "code": "<TmTimePicker @bind-Value=\"selectedTime\"\n              Label=\"Alarm\"\n              ShowSeconds=\"true\"\n              MinTime=\"@(new TimeOnly(6, 0))\"\n              MaxTime=\"@(new TimeOnly(22, 0))\" />"
    }
  ]
}