{
  "itemName": "TmAvatar",
  "kind": "Component",
  "category": "Avatars",
  "description": "Displays a user avatar as an image or initials fallback derived from the Name property. Supports six sizes (Xs, Sm, Md, Lg, Xl, Xxl), two shapes (Circle, Square), and multiple background colors for the initials variant.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Avatars"
  ],
  "parameters": [
    {
      "name": "Src",
      "type": "string?",
      "isRequired": false,
      "description": "Image source URL. When set, renders an img element."
    },
    {
      "name": "Alt",
      "type": "string?",
      "isRequired": false,
      "description": "Alt text for the avatar image."
    },
    {
      "name": "Name",
      "type": "string?",
      "isRequired": false,
      "description": "Full name used to derive initials when no Src is provided."
    },
    {
      "name": "Size",
      "type": "AvatarSize",
      "isRequired": false,
      "default": "Md",
      "description": "Display size. Defaults to Md."
    },
    {
      "name": "Shape",
      "type": "AvatarShape",
      "isRequired": false,
      "default": "Circle",
      "description": "Shape variant. Defaults to Circle."
    },
    {
      "name": "Color",
      "type": "AvatarColor",
      "isRequired": false,
      "default": "Gray",
      "description": "Background color for the initials fallback. Defaults to Gray."
    }
  ],
  "cssClasses": [
    "tm-avatar",
    "tm-avatar-xs",
    "tm-avatar-sm",
    "tm-avatar-md",
    "tm-avatar-lg",
    "tm-avatar-xl",
    "tm-avatar-2xl",
    "tm-avatar-circle",
    "tm-avatar-square",
    "tm-avatar-image",
    "tm-avatar-fallback"
  ],
  "examples": [
    {
      "title": "Avatar with image",
      "code": "<TmAvatar Src=\"/images/john.jpg\" Alt=\"John Doe\" Size=\"AvatarSize.Md\" />"
    },
    {
      "title": "Initials fallback",
      "code": "<TmAvatar Name=\"Jane Smith\" Size=\"AvatarSize.Lg\" Color=\"AvatarColor.Blue\" />"
    },
    {
      "title": "Square small avatar",
      "code": "<TmAvatar Name=\"Admin\" Size=\"AvatarSize.Sm\" Shape=\"AvatarShape.Square\" />"
    }
  ]
}