{
  "itemName": "TokenAutocomplete",
  "kind": "Component",
  "category": "Activity",
  "description": "Internal dropdown component for {{token}} variable selection in rich text editors. Displays token keys, descriptions, and optional category grouping with sticky section headers. Supports keyboard navigation, query-based filtering, and an optional \"Create new token\" action at the bottom.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Activity"
  ],
  "parameters": [
    {
      "name": "IsVisible",
      "type": "bool",
      "isRequired": false
    },
    {
      "name": "Tokens",
      "type": "IEnumerable<TokenItem>",
      "isRequired": false,
      "default": "Empty<TokenItem>()"
    },
    {
      "name": "Query",
      "type": "string",
      "isRequired": false,
      "default": "Empty"
    },
    {
      "name": "HighlightedIndex",
      "type": "int",
      "isRequired": false
    },
    {
      "name": "OnTokenSelected",
      "type": "EventCallback<TokenItem>",
      "isRequired": false
    },
    {
      "name": "OnCreateRequested",
      "type": "EventCallback<string?>",
      "isRequired": false
    },
    {
      "name": "IsLoading",
      "type": "bool",
      "isRequired": false
    },
    {
      "name": "SupportsCreation",
      "type": "bool",
      "isRequired": false
    },
    {
      "name": "OnHighlightedIndexChanged",
      "type": "EventCallback<int>",
      "isRequired": false
    }
  ],
  "cssClasses": [
    "tm-rte-token-dropdown",
    "tm-rte-token-item",
    "tm-rte-token-highlighted",
    "tm-rte-token-info",
    "tm-rte-token-key",
    "tm-rte-token-description",
    "tm-rte-token-category",
    "tm-rte-token-section-header",
    "tm-rte-token-empty",
    "tm-rte-token-separator",
    "tm-rte-token-create",
    "tm-rte-token-create-icon"
  ],
  "examples": [
    {
      "title": "Used internally by rich editors",
      "code": "<TokenAutocomplete IsVisible=\"true\" Tokens=\"@tokens\" Query=\"@query\" HighlightedIndex=\"0\" SupportsCreation=\"true\" OnTokenSelected=\"HandleSelected\" OnCreateRequested=\"HandleCreate\" OnHighlightedIndexChanged=\"HandleIndexChanged\" />"
    }
  ]
}