{
  "itemName": "TableDialog",
  "kind": "Component",
  "category": "Activity",
  "description": "Internal modal dialog for inserting tables in the rich text editor. Provides numeric row/column inputs (max 20x10) and a visual grid preview for interactive size selection with hover highlighting.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Activity"
  ],
  "parameters": [
    {
      "name": "IsVisible",
      "type": "bool",
      "isRequired": false
    },
    {
      "name": "CloseOnBackdropClick",
      "type": "bool",
      "isRequired": false,
      "default": "true"
    },
    {
      "name": "OnConfirm",
      "type": "EventCallback<(int Rows, int Cols)>",
      "isRequired": false
    },
    {
      "name": "OnCancel",
      "type": "EventCallback",
      "isRequired": false
    }
  ],
  "cssClasses": [
    "tm-rte-table-dialog",
    "tm-rte-table-backdrop",
    "tm-rte-table-content",
    "tm-rte-table-header",
    "tm-rte-table-body",
    "tm-rte-table-footer",
    "tm-rte-table-rows-input",
    "tm-rte-table-cols-input",
    "tm-rte-table-preview",
    "tm-rte-table-grid",
    "tm-rte-table-grid-row",
    "tm-rte-table-grid-cell",
    "tm-rte-table-size-label",
    "tm-rte-form-row",
    "tm-rte-btn-close",
    "tm-rte-btn-cancel",
    "tm-rte-btn-insert"
  ],
  "examples": [
    {
      "title": "Used internally by TmRichEditorFull",
      "code": "<TableDialog IsVisible=\"true\" OnConfirm=\"HandleTableConfirm\" OnCancel=\"HandleCancel\" />"
    }
  ]
}