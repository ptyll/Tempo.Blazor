{
  "itemName": "TmSkeleton",
  "kind": "Component",
  "category": "Feedback",
  "description": "Animated placeholder skeleton for loading states. Supports text, circle, and rectangle shape variants with configurable width and height.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Feedback"
  ],
  "parameters": [
    {
      "name": "Variant",
      "type": "SkeletonVariant",
      "isRequired": false,
      "default": "Text",
      "description": "Shape variant. Defaults to Text."
    },
    {
      "name": "Width",
      "type": "string?",
      "isRequired": false,
      "description": "Optional CSS width (e.g. \"200px\", \"100%\")."
    },
    {
      "name": "Height",
      "type": "string?",
      "isRequired": false,
      "description": "Optional CSS height (e.g. \"40px\", \"1rem\")."
    },
    {
      "name": "Class",
      "type": "string?",
      "isRequired": false,
      "description": "Additional CSS class."
    }
  ],
  "cssClasses": [
    "tm-skeleton",
    "tm-skeleton-text",
    "tm-skeleton-circle",
    "tm-skeleton-rect"
  ],
  "examples": [
    {
      "title": "Text skeleton",
      "code": "<TmSkeleton Variant=\"SkeletonVariant.Text\" Width=\"200px\" />"
    },
    {
      "title": "Circle avatar skeleton",
      "code": "<TmSkeleton Variant=\"SkeletonVariant.Circle\" Width=\"40px\" Height=\"40px\" />"
    },
    {
      "title": "Rectangle card skeleton",
      "code": "<TmSkeleton Variant=\"SkeletonVariant.Rect\" Width=\"100%\" Height=\"120px\" />"
    }
  ]
}