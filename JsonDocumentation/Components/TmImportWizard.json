{
  "itemName": "TmImportWizard",
  "kind": "Component",
  "category": "Import / Export",
  "description": "Multi-step import wizard with a step indicator (via TmStepper), back/next/cancel/complete navigation buttons, and customizable button text. Steps are defined as child TmImportWizardStep components.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.ImportExport"
  ],
  "parameters": [
    {
      "name": "ActiveStep",
      "type": "int",
      "isRequired": false,
      "description": "Zero-based index of the active step."
    },
    {
      "name": "ActiveStepChanged",
      "type": "EventCallback<int>",
      "isRequired": false,
      "description": "Fires when the active step changes."
    },
    {
      "name": "OnComplete",
      "type": "EventCallback",
      "isRequired": false,
      "description": "Fires when the wizard completes."
    },
    {
      "name": "OnCancel",
      "type": "EventCallback",
      "isRequired": false,
      "description": "Fires when the wizard is cancelled."
    },
    {
      "name": "CompleteText",
      "type": "string?",
      "isRequired": false,
      "description": "Custom text for Complete button."
    },
    {
      "name": "NextText",
      "type": "string?",
      "isRequired": false,
      "description": "Custom text for Next button."
    },
    {
      "name": "BackText",
      "type": "string?",
      "isRequired": false,
      "description": "Custom text for Back button."
    },
    {
      "name": "CancelText",
      "type": "string?",
      "isRequired": false,
      "description": "Custom text for Cancel button."
    },
    {
      "name": "ShowStepIndicator",
      "type": "bool",
      "isRequired": false,
      "default": "true",
      "description": "Whether to show the step indicator. Defaults to true."
    },
    {
      "name": "Class",
      "type": "string?",
      "isRequired": false,
      "description": "Additional CSS class(es)."
    }
  ],
  "cssClasses": [
    "tm-import-wizard",
    "tm-import-wizard-header",
    "tm-import-wizard-content",
    "tm-import-wizard-actions",
    "tm-import-wizard-actions-right"
  ],
  "examples": [
    {
      "title": "Three-step import wizard",
      "code": "<TmImportWizard @bind-ActiveStep=\"step\" OnComplete=\"@HandleComplete\" OnCancel=\"@HandleCancel\">\n    <TmImportWizardStep Title=\"Upload\" Icon=\"upload\">\n        <p>Upload your CSV file.</p>\n    </TmImportWizardStep>\n    <TmImportWizardStep Title=\"Map Columns\" Icon=\"columns\">\n        <p>Map file columns to fields.</p>\n    </TmImportWizardStep>\n    <TmImportWizardStep Title=\"Review\" Icon=\"check\">\n        <p>Review and confirm import.</p>\n    </TmImportWizardStep>\n</TmImportWizard>"
    }
  ]
}