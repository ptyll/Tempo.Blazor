{
  "itemName": "ImageDialog",
  "description": "Internal modal dialog for inserting images in the rich text editor. Provides URL and alt text inputs with URL validation and backdrop click to close.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Activity"
  ],
  "cssClasses": [
    "tm-rte-image-dialog",
    "tm-rte-image-backdrop",
    "tm-rte-image-content",
    "tm-rte-image-header",
    "tm-rte-image-body",
    "tm-rte-image-footer",
    "tm-rte-image-url-input",
    "tm-rte-image-alt-input",
    "tm-rte-btn-close",
    "tm-rte-btn-cancel",
    "tm-rte-btn-insert"
  ],
  "examples": [
    {
      "title": "Used internally by TmRichEditorFull",
      "code": "<ImageDialog IsVisible=\"true\" OnConfirm=\"HandleImageConfirm\" OnCancel=\"HandleCancel\" />"
    }
  ]
}