{
  "itemName": "TmModal",
  "kind": "Component",
  "category": "Feedback",
  "description": "Versatile modal dialog with header (title, subtitle, icon), scrollable body, and configurable footer with OK/Cancel buttons. Supports multiple sizes, positions, overlay click dismiss, and escape key handling.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Feedback"
  ],
  "parameters": [
    {
      "name": "Show",
      "type": "bool",
      "isRequired": false
    },
    {
      "name": "Title",
      "type": "string",
      "isRequired": false,
      "default": "Empty"
    },
    {
      "name": "Subtitle",
      "type": "string?",
      "isRequired": false
    },
    {
      "name": "Icon",
      "type": "string?",
      "isRequired": false
    },
    {
      "name": "Footer",
      "type": "RenderFragment?",
      "isRequired": false
    },
    {
      "name": "Size",
      "type": "ModalSize",
      "isRequired": false,
      "default": "Medium"
    },
    {
      "name": "Position",
      "type": "ModalPosition",
      "isRequired": false,
      "default": "Center"
    },
    {
      "name": "Animated",
      "type": "bool",
      "isRequired": false,
      "default": "true"
    },
    {
      "name": "ShowCloseButton",
      "type": "bool",
      "isRequired": false,
      "default": "true"
    },
    {
      "name": "ShowFooter",
      "type": "bool",
      "isRequired": false,
      "default": "true"
    },
    {
      "name": "ShowDefaultFooterButtons",
      "type": "bool",
      "isRequired": false,
      "default": "false"
    },
    {
      "name": "ShowOkButton",
      "type": "bool",
      "isRequired": false,
      "default": "true"
    },
    {
      "name": "ShowCancelButton",
      "type": "bool",
      "isRequired": false,
      "default": "true"
    },
    {
      "name": "OkButtonText",
      "type": "string",
      "isRequired": false,
      "default": "\"OK\""
    },
    {
      "name": "CancelButtonText",
      "type": "string",
      "isRequired": false,
      "default": "\"Cancel\""
    },
    {
      "name": "OkButtonVariant",
      "type": "ButtonVariant",
      "isRequired": false,
      "default": "Primary"
    },
    {
      "name": "OkButtonDisabled",
      "type": "bool",
      "isRequired": false,
      "default": "false"
    },
    {
      "name": "CloseOnOverlayClick",
      "type": "bool",
      "isRequired": false,
      "default": "true"
    },
    {
      "name": "CloseOnEscape",
      "type": "bool",
      "isRequired": false,
      "default": "true"
    },
    {
      "name": "OnClose",
      "type": "EventCallback",
      "isRequired": false
    },
    {
      "name": "OnOk",
      "type": "EventCallback",
      "isRequired": false
    },
    {
      "name": "OnOpen",
      "type": "EventCallback",
      "isRequired": false
    },
    {
      "name": "Class",
      "type": "string?",
      "isRequired": false
    }
  ],
  "cssClasses": [
    "tm-modal-overlay",
    "tm-modal--visible",
    "tm-modal--animated",
    "tm-modal-container",
    "tm-modal--center",
    "tm-modal--top",
    "tm-modal--bottom",
    "tm-modal",
    "tm-modal--sm",
    "tm-modal--md",
    "tm-modal--lg",
    "tm-modal--xl",
    "tm-modal--fullscreen",
    "tm-modal-header",
    "tm-modal-header-icon",
    "tm-modal-header-content",
    "tm-modal-title",
    "tm-modal-subtitle",
    "tm-modal-close",
    "tm-modal-body",
    "tm-modal-footer",
    "tm-modal-btn-cancel",
    "tm-modal-btn-ok"
  ],
  "examples": [
    {
      "title": "Basic modal with title and body",
      "code": "<TmModal Show=\"@isOpen\" Title=\"Confirm Action\" OnClose=\"() => isOpen = false\">\n    <p>Are you sure you want to proceed?</p>\n</TmModal>"
    },
    {
      "title": "Modal with default footer buttons",
      "code": "<TmModal Show=\"@isOpen\" Title=\"Edit Record\" Subtitle=\"Modify the fields below\"\n    Size=\"ModalSize.Large\" ShowDefaultFooterButtons=\"true\"\n    OkButtonText=\"Save\" CancelButtonText=\"Discard\"\n    OnOk=\"HandleSave\" OnClose=\"() => isOpen = false\">\n    <p>Form content here</p>\n</TmModal>"
    },
    {
      "title": "Modal with custom footer",
      "code": "<TmModal Show=\"@isOpen\" Title=\"Custom Footer\" OnClose=\"() => isOpen = false\">\n    <p>Body content</p>\n    <Footer>\n        <TmButton Variant=\"ButtonVariant.Danger\" OnClick=\"HandleDelete\">Delete</TmButton>\n        <TmButton Variant=\"ButtonVariant.Ghost\" OnClick=\"() => isOpen = false\">Cancel</TmButton>\n    </Footer>\n</TmModal>"
    }
  ]
}