{
  "itemName": "TmDateRangePicker",
  "kind": "Component",
  "category": "Pickers",
  "description": "Date range picker with dual side-by-side calendars, range preset buttons (Today, Last Week, Last Month, etc.), hover highlighting, and a two-click start/end selection flow.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Pickers",
    "@using Tempo.Blazor.Models"
  ],
  "parameters": [
    {
      "name": "Value",
      "type": "(DateOnly? Start, DateOnly? End)",
      "isRequired": true
    },
    {
      "name": "ValueChanged",
      "type": "EventCallback<(DateOnly? Start, DateOnly? End)>",
      "isRequired": false
    },
    {
      "name": "MinDate",
      "type": "DateOnly?",
      "isRequired": false
    },
    {
      "name": "MaxDate",
      "type": "DateOnly?",
      "isRequired": false
    },
    {
      "name": "DateFormat",
      "type": "string",
      "isRequired": false,
      "default": "\"dd.MM.yyyy\""
    },
    {
      "name": "Presets",
      "type": "IReadOnlyList<DateRangePreset>?",
      "isRequired": false
    },
    {
      "name": "ShowPresets",
      "type": "bool",
      "isRequired": false,
      "default": "true"
    },
    {
      "name": "Disabled",
      "type": "bool",
      "isRequired": false
    },
    {
      "name": "Placeholder",
      "type": "string?",
      "isRequired": false
    },
    {
      "name": "Label",
      "type": "string?",
      "isRequired": false
    },
    {
      "name": "Class",
      "type": "string?",
      "isRequired": false
    }
  ],
  "cssClasses": [
    "tm-date-range-picker",
    "tm-date-range-input-row",
    "tm-date-range-trigger",
    "tm-date-range-popup",
    "tm-date-range-calendars",
    "tm-date-range-footer",
    "tm-date-range-presets",
    "tm-date-range-preset-btn",
    "tm-picker-label",
    "tm-picker-clear",
    "tm-picker-placeholder"
  ],
  "examples": [
    {
      "title": "Basic date range picker",
      "code": "<TmDateRangePicker @bind-Value=\"dateRange\" Label=\"Report period\" />"
    },
    {
      "title": "Date range picker with custom presets",
      "code": "<TmDateRangePicker @bind-Value=\"dateRange\"\n                   Label=\"Filter dates\"\n                   Presets=\"@customPresets\"\n                   MinDate=\"@(new DateOnly(2025, 1, 1))\"\n                   DateFormat=\"yyyy-MM-dd\" />"
    }
  ]
}