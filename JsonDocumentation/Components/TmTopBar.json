{
  "itemName": "TmTopBar",
  "kind": "Component",
  "category": "Layout",
  "description": "Application top bar with brand area, center content slot, action buttons, command palette trigger, and user avatar menu with sign-out support.",
  "requiredImports": [
    "@using Tempo.Blazor.Components.Layout",
    "@using Tempo.Blazor.Interfaces"
  ],
  "parameters": [
    {
      "name": "BrandTitle",
      "type": "string?",
      "isRequired": false,
      "description": "Brand title text (simple string)."
    },
    {
      "name": "BrandContent",
      "type": "RenderFragment?",
      "isRequired": false,
      "description": "Custom brand content (logo, etc.)."
    },
    {
      "name": "CenterContent",
      "type": "RenderFragment?",
      "isRequired": false,
      "description": "Center slot content (e.g. breadcrumbs)."
    },
    {
      "name": "ActionsContent",
      "type": "RenderFragment?",
      "isRequired": false,
      "description": "Actions slot content (e.g. notification bell)."
    },
    {
      "name": "User",
      "type": "IUserInfo?",
      "isRequired": false,
      "description": "Currently logged-in user. When set, renders user avatar and menu."
    },
    {
      "name": "OnCommandPalette",
      "type": "EventCallback",
      "isRequired": false,
      "description": "Fires when the command palette trigger is clicked."
    },
    {
      "name": "OnLogout",
      "type": "EventCallback",
      "isRequired": false,
      "description": "Fires when the user clicks \"Sign out\"."
    },
    {
      "name": "Class",
      "type": "string?",
      "isRequired": false,
      "description": "Additional CSS class for the root element."
    }
  ],
  "cssClasses": [
    "tm-topbar",
    "tm-topbar-brand",
    "tm-topbar-brand-title",
    "tm-topbar-center",
    "tm-topbar-actions",
    "tm-topbar-search-trigger",
    "tm-topbar-search-hint",
    "tm-topbar-user",
    "tm-topbar-user-button",
    "tm-topbar-user-name",
    "tm-topbar-user-menu",
    "tm-topbar-user-menu-item",
    "tm-topbar-user-menu-logout",
    "tm-topbar-icon-btn"
  ],
  "examples": [
    {
      "title": "Top bar with brand, user, and command palette",
      "code": "<TmTopBar BrandTitle=\"My App\"\n          User=\"currentUser\"\n          OnCommandPalette=\"OpenCommandPalette\"\n          OnLogout=\"HandleLogout\" />"
    },
    {
      "title": "Top bar with custom center content",
      "code": "<TmTopBar BrandTitle=\"Admin\">\n    <CenterContent>\n        <TmBreadcrumbs Items=\"breadcrumbs\" />\n    </CenterContent>\n    <ActionsContent>\n        <TmNotificationBell Notifications=\"notifications\" />\n    </ActionsContent>\n</TmTopBar>"
    }
  ]
}